---
// src/pages/index.astro
import { getCollection } from "astro:content";
import Sidebar from "../components/Sidebar.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

const allWork = await getCollection("work");
const featuredWork = allWork
  .filter((w) => w.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const allPosts = await getCollection("blog");
const latestPosts = allPosts
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 2);

const categoryLabel: Record<string, string> = {
  craft: "Craft",
  notes: "Notes",
  family: "Family",
};

const year = new Date().getFullYear();
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Teguh Suwanda</title>
    <meta
      name="description"
      content="Engineer by day, illustrator by passion, family man by purpose."
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <script is:inline>
      const theme =
        localStorage.getItem("theme") ??
        (window.matchMedia("(prefers-color-scheme: dark)").matches
          ? "dark"
          : "light");
      document.documentElement.classList.toggle("dark", theme === "dark");
    </script>
  </head>

  <body class="home-body">
    <!-- Sidebar — komponen yang sama dengan BaseLayout / About -->
    <Sidebar />

    <!-- ════════════════════════════════════
         SNAP CONTAINER
         Menempel ke kanan sidebar (margin-left 16rem)
         Sidebar.astro sudah menangani mobile bar sendiri,
         jadi kita tinggal offset padding-top di mobile.
    ════════════════════════════════════ -->
    <div class="snap-container" id="snap-container">
      <!-- ══ SECTION 0 — HERO ══ -->
      <section class="snap-section section--hero" data-index="0">
        <div class="hero-layout">
          <div class="hero-text">
            <p class="hero-eyebrow">About Me</p>

            <!-- Tipografi identik dengan .ab-hero-heading + .ab-hero-heading-serif di about.astro -->
            <h1 class="hero-heading">
              Engineer <em>by day,</em><br />
              Illustrator <em>by passion,</em><br />
              Husband, Father, <em>still learning.</em>
            </h1>

            <p class="hero-lead">
              I build things—sometimes with code, sometimes with imagination and
              learning along the way what truly matters.
            </p>

            <div class="hero-accent-bar" aria-hidden="true"></div>

            <div class="hero-actions">
              <a href="/work" class="btn-primary">Explore my works</a>
              <a href="/about" class="btn-ghost">Get to know me</a>
            </div>
          </div>

          <div class="hero-deco" aria-hidden="true">
            <span class="hero-deco-word"></span>
          </div>
        </div>

        <div class="scroll-hint" aria-hidden="true">
          <span class="scroll-hint-label">scroll</span>
          <div class="scroll-hint-line"></div>
        </div>
      </section>

      <!-- ══ SECTION 1 — SELECTED WORKS ══ -->
      <section class="snap-section section--works" data-index="1">
        <div class="works-inner">
          <div class="works-header">
            <p class="works-eyebrow">SELECTED WORKS</p>
            <span class="works-year">2023 — {year}</span>
          </div>

          <!-- Zero-gap grid: 8fr feature + 4fr sidebar stack — persis code.html -->
          <div class="works-grid">
            <div class="works-feature">
              {
                featuredWork[0] ? (
                  <a href={`/work/${featuredWork[0].id}`} class="grid-cell">
                    {featuredWork[0].data.cover ? (
                      <img
                        src={featuredWork[0].data.cover}
                        alt={
                          featuredWork[0].data.coverAlt ??
                          featuredWork[0].data.title
                        }
                        loading="eager"
                        decoding="async"
                      />
                    ) : (
                      <div class="grid-noimage">
                        <span>{featuredWork[0].data.title.charAt(0)}</span>
                      </div>
                    )}
                  </a>
                ) : (
                  <div class="grid-cell">
                    <div class="grid-noimage">
                      <span>A</span>
                    </div>
                  </div>
                )
              }
            </div>

            <div class="works-stack">
              {
                featuredWork[1] ? (
                  <a href={`/work/${featuredWork[1].id}`} class="grid-cell">
                    {featuredWork[1].data.cover ? (
                      <img
                        src={featuredWork[1].data.cover}
                        alt={
                          featuredWork[1].data.coverAlt ??
                          featuredWork[1].data.title
                        }
                        loading="lazy"
                        decoding="async"
                      />
                    ) : (
                      <div class="grid-noimage">
                        <span>{featuredWork[1].data.title.charAt(0)}</span>
                      </div>
                    )}
                  </a>
                ) : (
                  <div class="grid-cell">
                    <div class="grid-noimage">
                      <span>B</span>
                    </div>
                  </div>
                )
              }

              {
                featuredWork[2] ? (
                  <a href={`/work/${featuredWork[2].id}`} class="grid-cell">
                    {featuredWork[2].data.cover ? (
                      <img
                        src={featuredWork[2].data.cover}
                        alt={
                          featuredWork[2].data.coverAlt ??
                          featuredWork[2].data.title
                        }
                        loading="lazy"
                        decoding="async"
                      />
                    ) : (
                      <div class="grid-noimage">
                        <span>{featuredWork[2].data.title.charAt(0)}</span>
                      </div>
                    )}
                  </a>
                ) : (
                  <div class="grid-cell">
                    <div class="grid-noimage">
                      <span>C</span>
                    </div>
                  </div>
                )
              }
            </div>
          </div>
        </div>
      </section>

      <!-- ══ SECTION 2 — RECENT REFLECTIONS ══ -->
      <section class="snap-section section--blog" data-index="2">
        <div class="blog-inner">
          <p class="blog-eyebrow">RECENT REFLECTIONS</p>

          <div class="blog-grid">
            {
              latestPosts.length === 0 ? (
                <>
                  <article class="blog-article">
                    <div class="article-meta">
                      <span class="article-cat">SELF-DEVELOPMENT</span>
                    </div>
                    <h4 class="article-title">
                      The Art of Deliberate Practice in Engineering
                    </h4>
                    <p class="article-excerpt">
                      Bagaimana memperlakukan arsitektur software layaknya
                      masterclass ilustrasi dapat mengubah cara kita mendekati
                      pemecahan masalah yang kompleks...
                    </p>
                    <span class="article-cta">
                      READ JOURNAL
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                      >
                        <path d="M5 12h14M13 6l6 6-6 6" />
                      </svg>
                    </span>
                  </article>

                  <article class="blog-article">
                    <div class="article-meta">
                      <span class="article-cat">PHILOSOPHY</span>
                    </div>
                    <h4 class="article-title">
                      Finding Stillness in the Middle of the Grind
                    </h4>
                    <p class="article-excerpt">
                      Refleksi tentang mempertahankan output kreatif sembari
                      menjalani karier engineering penuh waktu dan kekacauan
                      indah kehidupan keluarga...
                    </p>
                    <span class="article-cta">
                      READ JOURNAL
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                      >
                        <path d="M5 12h14M13 6l6 6-6 6" />
                      </svg>
                    </span>
                  </article>
                </>
              ) : (
                latestPosts.map((post) => (
                  <article class="blog-article">
                    <div class="article-meta">
                      <span class="article-cat">
                        {categoryLabel[post.data.category]?.toUpperCase()}
                      </span>
                    </div>
                    <h4 class="article-title">{post.data.title}</h4>
                    <p class="article-excerpt">{post.data.description}</p>
                    <a href={`/blog/${post.id}`} class="article-cta">
                      READ JOURNAL
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                      >
                        <path d="M5 12h14M13 6l6 6-6 6" />
                      </svg>
                    </a>
                  </article>
                ))
              )
            }
          </div>
        </div>
        <Footer />
      </section>
    </div><!-- /snap-container -->

    <!-- Section dots -->
    <nav class="section-dots" id="section-dots" aria-label="Section navigator">
      <button class="dot dot--active" data-target="0" aria-label="Hero"
      ></button>
      <button class="dot" data-target="1" aria-label="Works"></button>
      <button class="dot" data-target="2" aria-label="Blog"></button>
    </nav>
  </body>
</html>

<style>
  /* ══════════════════════════════════════════
     HOME BODY
     Sidebar.astro sudah fixed position sendiri (width 16rem).
     Body tidak overflow — snap hanya di .snap-container.
  ══════════════════════════════════════════ */
  .home-body {
    overflow: hidden;
    height: 100dvh;
  }

  /* ══════════════════════════════════════════
     SNAP CONTAINER
     Menggunakan margin-left 16rem agar tidak tertutup sidebar,
     sama persis dengan .layout-main di BaseLayout.astro.
  ══════════════════════════════════════════ */
  .snap-container {
    margin-left: 16rem; /* lebar sidebar — sama dengan BaseLayout */
    height: 100dvh;
    overflow-y: scroll;
    overflow-x: hidden;
    scroll-snap-type: y mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
    background: #fcf9f8;
    transition: background 0.3s;
  }
  :root.dark .snap-container {
    background: #141412;
  }
  .snap-container::-webkit-scrollbar {
    display: none;
  }

  /* ══════════════════════════════════════════
     SNAP SECTIONS — tiap section = 100dvh
  ══════════════════════════════════════════ */
  .snap-section {
    scroll-snap-align: start;
    scroll-snap-stop: always;
    height: 100dvh;
    width: 100%;
    display: flex;
    position: relative;
    opacity: 0;
    transform: translateY(12px);
    transition:
      opacity 0.5s ease,
      transform 0.5s ease;
  }
  .snap-section.in-view {
    opacity: 1;
    transform: translateY(0);
  }

  /* ══════════════════════════════════════════
     SECTION 0 — HERO
     Tipografi identik dengan about.astro .intro-heading
  ══════════════════════════════════════════ */
  .section--hero {
    background: var(--color-bg);
    align-items: center;
    justify-content: center;
  }

  .hero-layout {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 2rem;
    width: 100%;
    max-width: 72rem;
    padding: 0 4rem;
  }

  /* Identik .intro-eyebrow di about.astro */
  .hero-eyebrow {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin: 0 0 1rem;
  }

  /* Identik .ab-hero-heading di about.astro */
  .hero-heading {
    font-family: var(--font-sans);
    font-size: clamp(2.25rem, 5.5vw, 3.75rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--color-text);
    margin: 0 0 2rem;
  }
  .hero-heading em {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    color: var(--color-accent);
  }

  /* Identik .ab-hero-lead di about.astro */
  .hero-lead {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.25rem;
    line-height: 1.75;
    color: var(--color-text-muted);
    max-width: 46ch;
    margin: 0 0 2rem;
  }

  .hero-accent-bar {
    width: 2.5rem;
    height: 3px;
    background: var(--color-accent);
    border-radius: 99px;
    margin-bottom: 2rem;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.625rem 1.25rem;
    border-radius: 8px;
    background: var(--color-accent);
    color: #fff;
    transition: opacity 0.15s;
  }
  .btn-primary:hover {
    opacity: 0.85;
  }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.625rem 1.25rem;
    border-radius: 8px;
    border: 1px solid var(--color-border);
    color: var(--color-text);
    transition: background 0.15s;
  }
  .btn-ghost:hover {
    background: var(--color-bg-subtle);
  }

  /* Dekorasi kata serif besar kanan */
  .hero-deco {
    flex-shrink: 0;
    user-select: none;
  }
  .hero-deco-word {
    font-family: var(--font-serif);
    font-size: clamp(5rem, 10vw, 9rem);
    font-style: italic;
    font-variation-settings:
      "opsz" 9,
      "SOFT" 100;
    color: var(--color-border);
    letter-spacing: -0.04em;
    line-height: 1;
    display: block;
  }

  /* Scroll hint */
  .scroll-hint {
    position: absolute;
    bottom: 1.75rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
  }
  .scroll-hint-label {
    font-size: 0.6rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-border);
  }
  .scroll-hint-line {
    width: 1px;
    height: 2rem;
    background: linear-gradient(to bottom, var(--color-border), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
    transform-origin: top;
  }
  @keyframes scrollPulse {
    0%,
    100% {
      opacity: 0.3;
      transform: scaleY(0.5);
    }
    50% {
      opacity: 1;
      transform: scaleY(1);
    }
  }

  /* ══════════════════════════════════════════
     SECTION 1 — SELECTED WORKS
     Identik code.html: zero-gap, grayscale→color
  ══════════════════════════════════════════ */
  .section--works {
    background: var(--color-bg);
    align-items: stretch;
    flex-direction: column;
  }

  .works-inner {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* "px-8 md:px-20" dari code.html */
  .works-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: 2.5rem 5rem 1.25rem;
    flex-shrink: 0;
    /* Tinggi header row yang kita pakai sebagai acuan calc di bawah */
    height: 5.5rem;
  }
  /* "text-xs font-label uppercase tracking-[0.3em]" */
  .works-eyebrow {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }
  /* "text-xs italic text-outline-variant" */
  .works-year {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-style: italic;
    color: var(--color-text-muted);
    opacity: 0.5;
  }

  /*
    Grid zero-gap.
    Tinggi eksplisit = 100dvh dikurangi tinggi header row (5.5rem).
    Ini memastikan kedua gambar sidebar persis setengah-setengah
    tanpa bergantung pada flex sizing yang tidak konsisten.
  */
  .works-grid {
    display: grid;
    grid-template-columns: 8fr 4fr;
    grid-template-rows: calc(100dvh - 5.5rem);
    gap: 0;
    overflow: hidden;
  }
  .works-feature {
    overflow: hidden;
    height: 100%;
  }
  .works-stack {
    display: grid;
    grid-template-rows: 1fr 1fr; /* dua baris sama tinggi */
    gap: 0;
    height: 100%;
  }

  .grid-cell {
    display: block;
    width: 100%;
    height: 100%;
    overflow: hidden;
    position: relative;
    background: var(--color-bg-subtle);
  }
  /* "grayscale hover:grayscale-0 transition-all duration-700" */
  .grid-cell img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: grayscale(100%);
    transition:
      filter 0.7s ease,
      transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    cursor: pointer;
  }
  .grid-cell:hover img {
    filter: grayscale(0%);
    transform: scale(1.03);
  }
  .grid-noimage {
    width: 100%;
    height: 100%;
    min-height: 140px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-serif);
    font-size: 3rem;
    font-style: italic;
    color: var(--color-border);
    background: var(--color-bg-subtle);
  }

  /* ══════════════════════════════════════════
     SECTION 2 — RECENT REFLECTIONS
     Identik code.html: 2-col, cat label, "READ JOURNAL →"
  ══════════════════════════════════════════ */
  .section--blog {
    background: var(--color-bg);
    align-items: stretch;
    flex-direction: column;
  }

  .blog-inner {
    width: 100%;
    flex: 1;
    display: flex;
    flex-direction: column;
    /* "px-8 md:px-20 py-32" dari code.html */
    padding: 4rem 5rem 0;
  }

  /* "text-xs uppercase tracking-[0.3em] mb-16" */
  .blog-eyebrow {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 4rem;
    flex-shrink: 0;
  }

  /* "grid-cols-2 gap-16 md:gap-24" */
  .blog-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem 6rem;
    align-content: start; /* grid tidak stretch ke bawah */
  }

  .blog-article {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }
  .blog-article a {
    text-decoration: none;
    color: inherit;
  }

  .article-meta {
    margin-bottom: 0.5rem;
  }

  /* "text-xs text-primary-container font-semibold" */
  .article-cat {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  /* "text-2xl font-bold font-headline group-hover:text-primary" */
  .article-title {
    font-family: var(--font-sans);
    font-size: clamp(1.25rem, 2vw, 1.5rem);
    font-variation-settings: "opsz" 9;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.3;
    margin-bottom: 1rem;
    transition: color 0.2s;
  }
  .blog-article:hover .article-title {
    color: var(--color-accent);
  }

  /* "text-on-surface-variant leading-relaxed" */
  .article-excerpt {
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: 1.25rem;
    /* Tidak pakai flex:1 — biar CTA tetap rapat di bawah excerpt */
  }

  /* "inline-flex text-xs font-bold tracking-widest" */
  .article-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.2s;
  }
  .blog-article:hover .article-cta {
    color: var(--color-accent);
  }
  .article-cta svg {
    transition: transform 0.2s;
  }
  .blog-article:hover .article-cta svg {
    transform: translateX(3px);
  }

  /* ══ SECTION DOTS ══ */
  .section-dots {
    position: fixed;
    right: 1.25rem;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    z-index: 30;
  }
  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    border: none;
    background: var(--color-border);
    cursor: pointer;
    padding: 0;
    transition:
      background 0.25s,
      transform 0.25s;
  }
  .dot--active {
    background: var(--color-accent);
    transform: scale(1.4);
  }

  /* ══════════════════════════════════════════
     RESPONSIVE
     Sidebar.astro sudah handle breakpoint 768px:
     - ≤768px: sidebar hilang, mobile-bar + drawer muncul
     - ≥769px: mobile-bar hilang
     Kita tinggal sesuaikan margin snap-container.
  ══════════════════════════════════════════ */
  @media (max-width: 768px) {
    .snap-container {
      margin-left: 0;
      /* Sidebar.astro mobile-bar height = 3.25rem */
      padding-top: 3.25rem;
      height: 100dvh;
    }
    .snap-section {
      height: calc(100dvh - 3.25rem);
    }
    .section-dots {
      display: none;
    }

    /* Hero */
    .hero-layout {
      grid-template-columns: 1fr;
      padding: 1.5rem 1.25rem;
      gap: 0;
    }
    .hero-deco {
      display: none;
    }
    .hero-lead {
      max-width: 100%;
    }
    .scroll-hint {
      display: none;
    }

    /* Works */
    .works-header {
      padding: 1.5rem 1.25rem 0.75rem;
    }
    .works-grid {
      grid-template-columns: 1fr;
      grid-template-rows: 2fr 1fr;
    }
    .works-stack {
      grid-template-rows: 1fr;
      grid-template-columns: 1fr 1fr;
    }

    /* Blog */
    .blog-inner {
      padding: 2rem 1.25rem 0;
    }
    .blog-eyebrow {
      margin-bottom: 1.75rem;
    }
    .blog-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
      overflow-y: auto;
    }
    .blog-footer {
      padding: 1rem 0;
    }
  }

  @media (min-width: 769px) and (max-width: 1100px) {
    .hero-layout {
      padding: 0 2.5rem;
    }
    .works-header {
      padding: 2rem 2.5rem 1rem;
    }
    .blog-inner {
      padding: 3rem 2.5rem 0;
    }
    .blog-grid {
      gap: 3rem 3rem;
    }
    .blog-eyebrow {
      margin-bottom: 2.5rem;
    }
  }
</style>

<script>
  // ── Scroll snap ──
  const container = document.getElementById("snap-container")!;
  const sections = document.querySelectorAll<HTMLElement>(".snap-section");
  const dots = document.querySelectorAll<HTMLButtonElement>(".dot");

  const H = () => container.clientHeight;

  function goTo(idx: number) {
    container.scrollTo({ top: idx * H(), behavior: "smooth" });
  }

  function onScroll() {
    const idx = Math.round(container.scrollTop / H());
    dots.forEach((d, i) => d.classList.toggle("dot--active", i === idx));
  }

  container.addEventListener("scroll", onScroll, { passive: true });
  dots.forEach((dot, i) => dot.addEventListener("click", () => goTo(i)));

  // Fade-in section pertama langsung
  sections[0].classList.add("in-view");

  // Fade-in per section via IntersectionObserver
  const obs = new IntersectionObserver(
    (entries) =>
      entries.forEach((e) => {
        if (e.isIntersecting) e.target.classList.add("in-view");
      }),
    { threshold: 0.3, root: container },
  );
  sections.forEach((s) => obs.observe(s));
</script>
