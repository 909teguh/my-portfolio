---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Ambil karya yang featured, urutkan by order
const allWork = await getCollection('work');
const featuredWork = allWork
  .filter(w => w.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 8); // ambil hingga 8 untuk masonry

// Ambil 3 blog post terbaru yang bukan draft
const allPosts = await getCollection('blog');
const latestPosts = allPosts
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

// Format tanggal
const formatDate = (date: Date) =>
  date.toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' });

// Label kategori blog
const categoryLabel: Record<string, string> = {
  craft:  'Craft',
  notes:  'Notes',
  family: 'Family',
};

const typeLabel: Record<string, string> = {
  illustration: 'Illustration',
  commission: 'Commission',
  generative: 'Generative',
  other: 'Other',
};
---

<BaseLayout
  title="Home"
  description="Engineer by day, illustrator by passion, family man by purpose."
>

  <!-- ============================================================
       HERO
  ============================================================ -->
  <section class="hero">
    <div class="hero-bg-image">
      <img src="/images/portfolio1.jpg" alt="" aria-hidden="true" />
    </div>
    <div class="hero-inner">
      <div class="hero-text">
        <p class="hero-eyebrow">Halo, saya</p>
        <h1 class="hero-name">Teguh Suwanda</h1>
        <p class="hero-tagline">
          Engineer by day,<br />
          illustrator by passion,<br />
          family man by purpose.
        </p>
        <p class="hero-bio">Saya membangun software di siang hari dan menggambar di malam hari.
              Di sini saya berbagi karya, proses, dan catatan kecil tentang hidup
              yang pelan-pelan menjadi bermakna.</p>
        <div class="hero-actions">
          <a href="/work" class="btn btn--primary">Lihat karya</a>
          <a href="/blog" class="btn btn--ghost">Baca tulisan</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SELECTED WORK — Pinterest Masonry
  ============================================================ -->
  <section class="section">
    <div class="container">

      <div class="section-header">
        <h2 class="section-title">Selected Work</h2>
        <a href="/work" class="section-link">All work →</a>
      </div>

      {featuredWork.length === 0 ? (
        <div class="featured-grid">
          {[1, 2, 3, 4].map((i) => (
            <div class="featured-card featured-card--placeholder">
              <div class="featured-card__image-wrap">
                <div class="featured-card__noimage">
                  <span>{i}</span>
                </div>
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div class="featured-grid">
          {featuredWork.map((work) => (
            <a
              href={`/work/${work.id}`}
              class="featured-card"
              aria-label={work.data.title}
            >
              <div class="featured-card__image-wrap">
                {work.data.cover ? (
                  <img
                    class="featured-card__img"
                    src={work.data.cover}
                    alt={work.data.coverAlt ?? ''}
                    loading="lazy"
                    decoding="async"
                  />
                ) : (
                  <div class="featured-card__noimage">
                    <span>{work.data.title.charAt(0)}</span>
                  </div>
                )}

                <!-- Overlay -->
                <div class="featured-card__overlay" aria-hidden="true">
                  <div class="featured-card__overlay-inner">
                    <p class="featured-card__overlay-title">{work.data.title}</p>
                    <div class="featured-card__overlay-meta">
                      <span class="featured-card__overlay-type">
                        {typeLabel[work.data.type] ?? work.data.type}
                      </span>
                      <span class="featured-card__overlay-year">{work.data.year}</span>
                    </div>
                  </div>
                </div>
              </div>
            </a>
          ))}
        </div>
      )}

    </div>
  </section>

  <!-- ============================================================
       LATEST POSTS
  ============================================================ -->
  <section class="section section--tinted">
    <div class="container">

      <div class="section-header">
        <h2 class="section-title">From the blog</h2>
        <a href="/blog" class="section-link">All posts →</a>
      </div>

      {latestPosts.length === 0 ? (
        <div class="posts-list">
          {[
            { title: 'Kenapa saya akhirnya membuat website ini', cat: 'notes', date: 'hari ini' },
            { title: 'Belajar menggambar di tengah jadwal yang padat', cat: 'craft', date: 'minggu lalu' },
            { title: 'Hal-hal kecil yang saya syukuri sebagai ayah', cat: 'family', date: 'bulan lalu' },
          ].map(p => (
            <div class="post-item post-item--placeholder">
              <div class="post-item-left">
                <span class={`post-cat post-cat--${p.cat}`}>{categoryLabel[p.cat]}</span>
                <p class="post-title">{p.title}</p>
              </div>
              <span class="post-date">{p.date}</span>
            </div>
          ))}
        </div>
      ) : (
        <div class="posts-list">
          {latestPosts.map(post => (
            <a href={`/blog/${post.id}`} class="post-item">
              <div class="post-item-left">
                <span class={`post-cat post-cat--${post.data.category}`}>
                  {categoryLabel[post.data.category]}
                </span>
                <p class="post-title">{post.data.title}</p>
              </div>
              <span class="post-date">{formatDate(post.data.pubDate)}</span>
            </a>
          ))}
        </div>
      )}

    </div>
  </section>

  <!-- ============================================================
       ABOUT SNIPPET
  ============================================================ -->
  <section class="section">
    <div class="container">
      <div class="about-snippet">
        <div class="about-snippet-text">
          <h2 class="about-snippet-title">A bit about me</h2>
          <p>
            Saya seorang software engineer yang menemukan ketenangan dalam menggambar.
            Dua dunia yang kelihatannya berbeda — tapi bagi saya, keduanya sama: soal
            membangun sesuatu yang bermakna, satu langkah kecil dalam satu waktu.
          </p>
          <p>
            Di luar layar dan kanvas, saya adalah suami dan ayah yang sedang belajar
            hadir sepenuhnya.
          </p>
          <a href="/about" class="btn btn--ghost" style="margin-top: 1.25rem; display: inline-flex;">
            More about me →
          </a>
        </div>
        <div class="about-snippet-deco" aria-hidden="true">
          <span class="deco-word">engineer</span>
          <span class="deco-word deco-word--accent">illustrator</span>
          <span class="deco-word">father</span>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Layout helpers ── */
  .container {
    max-width: 80rem;
    margin-inline: auto;
    padding-inline: 1.5rem;
  }

  .section {
    padding-block: 5rem;
  }

  .section--tinted {
    background-color: var(--color-bg-subtle);
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1.75rem;
  }

  .section-title {
    font-size: clamp(1.25rem, 2vw, 1.625rem);
    color: var(--color-text);
    margin: 0;
  }

  .section-link {
    font-size: 0.875rem;
    color: var(--color-accent);
    transition: opacity 0.15s;
  }

  .section-link:hover { opacity: 0.75; }

  /* ── Buttons ── */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.625rem 1.25rem;
    border-radius: 8px;
    transition: background-color 0.15s, color 0.15s, opacity 0.15s;
    cursor: pointer;
  }

  .btn--primary {
    background-color: var(--color-accent);
    color: #fff;
  }

  .btn--primary:hover { opacity: 0.85; }

  .btn--ghost {
    border: 1px solid var(--color-border);
    color: var(--color-text);
    background: transparent;
  }

  .btn--ghost:hover { background-color: var(--color-bg-subtle); }

  /* ── Hero ── */
  .hero {
    position: relative;
    min-height: 520px;
    overflow: hidden;
    border-bottom: 1px solid var(--color-border);
    display: flex;
    align-items: center;
  }

  .hero-bg-image {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-bg-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center right;
  }

  .hero-bg-image::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      var(--color-bg) 0%,
      var(--color-bg) 40%,
      color-mix(in srgb, var(--color-bg) 50%, transparent) 55%,
      transparent 70%
    );
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 80rem;
    margin-inline: auto;
    padding: 6rem 1.5rem;
    width: 100%;
  }

  .hero-text { max-width: 52ch; }

  .hero-eyebrow {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 0 0 0.5rem;
    letter-spacing: 0.03em;
  }

  .hero-name {
    font-size: clamp(2.5rem, 6vw, 4rem);
    margin: 0 0 1.25rem;
    color: var(--color-text);
    line-height: 1;
  }

  .hero-tagline {
    font-family: var(--font-serif);
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: var(--color-text-muted);
    font-style: italic;
    line-height: 1.7;
    margin: 0 0 1.5rem;
    font-variation-settings: "opsz" 9, "SOFT" 100;
  }

  .hero-bio {
    font-size: 1rem;
    color: var(--color-text-muted);
    max-width: 48ch;
    margin: 0 0 2rem;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  /* ── Featured Grid — portrait 1:2, max 4 per baris ── */
  .featured-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
  }

  /* ── Featured Card ── */
  .featured-card {
    display: block;
    text-decoration: none;
    color: inherit;
    border-radius: 12px;
    overflow: hidden;
  }

  .featured-card__image-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 2 / 3;   /* portrait memanjang */
    overflow: hidden;
    border-radius: 12px;
    background: var(--color-bg-subtle);
  }

  .featured-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.45s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .featured-card:hover .featured-card__img {
    transform: scale(1.05);
  }

  .featured-card__noimage {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-serif);
    font-size: 3rem;
    font-style: italic;
    color: var(--color-text-muted);
  }

  /* Overlay gelap dari bawah */
  .featured-card__overlay {
    position: absolute;
    inset: 0;
    border-radius: 12px;
    background: linear-gradient(
      to top,
      color-mix(in srgb, #000 80%, transparent) 0%,
      color-mix(in srgb, #000 25%, transparent) 35%,
      transparent 60%
    );
    display: flex;
    align-items: flex-end;
    opacity: 0;
    transition: opacity 0.35s ease;
    pointer-events: none;
  }

  .featured-card:hover .featured-card__overlay,
  .featured-card.is-visible .featured-card__overlay {
    opacity: 1;
  }

  .featured-card__overlay-inner {
    padding: 1.125rem 1rem 1rem;
    width: 100%;
    transform: translateY(8px);
    transition: transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .featured-card:hover .featured-card__overlay-inner,
  .featured-card.is-visible .featured-card__overlay-inner {
    transform: translateY(0);
  }

  .featured-card__overlay-title {
    font-size: 0.875rem;
    font-weight: 500;
    color: #fff;
    margin: 0 0 0.3rem;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .featured-card__overlay-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .featured-card__overlay-type {
    font-size: 0.65rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: rgba(255, 255, 255, 0.65);
  }

  .featured-card__overlay-year {
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.5);
    font-family: var(--font-serif);
    font-style: italic;
  }

  /* ── Blog posts list ── */
  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .post-item {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 2rem;
    padding-block: 1.125rem;
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
    color: inherit;
    transition: background-color 0.15s;
    border-radius: 4px;
  }

  .post-item:first-child { border-top: 1px solid var(--color-border); }

  .post-item:not(.post-item--placeholder):hover {
    background-color: var(--color-bg-subtle);
    padding-inline: 0.75rem;
    margin-inline: -0.75rem;
  }

  .post-item-left {
    display: flex;
    align-items: baseline;
    gap: 0.875rem;
    flex: 1;
    min-width: 0;
  }

  .post-cat {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    flex-shrink: 0;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
  }

  .post-cat--notes  { background: var(--color-bg-subtle); color: var(--color-text-muted); }
  .post-cat--craft  { background: var(--color-accent-soft); color: var(--color-accent); }
  .post-cat--family {
    background: color-mix(in srgb, #16a34a 10%, transparent);
    color: #16a34a;
  }

  .post-title {
    font-size: 0.9375rem;
    margin: 0;
    color: var(--color-text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .post-date {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    flex-shrink: 0;
  }

  /* ── About snippet ── */
  .about-snippet {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 4rem;
    align-items: center;
  }

  .about-snippet-title {
    font-size: clamp(1.25rem, 2vw, 1.625rem);
    margin: 0 0 1rem;
  }

  .about-snippet-text p {
    color: var(--color-text-muted);
    margin: 0 0 0.875rem;
    max-width: 52ch;
  }

  .about-snippet-deco {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.25rem;
    user-select: none;
  }

  .deco-word {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-style: italic;
    font-variation-settings: "opsz" 9, "SOFT" 100;
    color: var(--color-border);
    line-height: 1.2;
    letter-spacing: -0.02em;
    transition: color 0.2s;
  }

  .deco-word--accent { color: var(--color-accent); opacity: 0.3; }

  .about-snippet:hover .deco-word { color: var(--color-text-muted); }
  .about-snippet:hover .deco-word--accent { opacity: 0.6; }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .featured-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 8px;
    }

    .hero-inner {
      padding: 4rem 1.5rem;
    }

    .about-snippet {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .about-snippet-deco { display: none; }

    .post-item { flex-direction: column; gap: 0.25rem; }
  }

  @media (min-width: 641px) and (max-width: 900px) {
    .featured-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>

<script>
  // Overlay muncul saat card terlihat di viewport saat scroll
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        const card = entry.target as HTMLElement;
        if (entry.isIntersecting) {
          card.classList.add('is-visible');
        } else {
          card.classList.remove('is-visible');
        }
      });
    },
    { threshold: 0.2, rootMargin: '0px 0px -5% 0px' }
  );

  document.querySelectorAll<HTMLElement>('.featured-card').forEach((card) => {
    observer.observe(card);
  });
</script>