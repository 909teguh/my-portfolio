---
// src/pages/index.astro
import { getCollection } from "astro:content";
import Nav from "../components/Nav.astro";
import "../styles/global.css";

const allWork = await getCollection("work");
const featuredWork = allWork
  .filter((w) => w.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const allPosts = await getCollection("blog");
const latestPosts = allPosts
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 2);

const categoryLabel: Record<string, string> = {
  craft: "Craft",
  notes: "Notes",
  family: "Family",
};

const year = new Date().getFullYear();
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Teguh Suwanda</title>
    <meta
      name="description"
      content="Engineer by day, illustrator by passion, family man by purpose."
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <script is:inline>
      const theme =
        localStorage.getItem("theme") ??
        (window.matchMedia("(prefers-color-scheme: dark)").matches
          ? "dark"
          : "light");
      document.documentElement.classList.toggle("dark", theme === "dark");
    </script>
  </head>

  <body class="home-body">
    <!-- ── Nav: komponen yang sama dengan About/Blog/Work ── -->
    <Nav />

    <!-- ── Snap Container ── -->
    <div class="snap-container" id="snap-container">
      <!-- ══════════════════════════════
           SECTION 0 — HERO
      ══════════════════════════════ -->
      <section class="snap-section section--hero" id="s0" data-index="0">
        <div class="hero-layout">
          <div class="hero-text">
            <p class="hero-eyebrow">Tentang saya</p>

            <!--
              Tipografi SAMA PERSIS dengan about.astro .intro-heading:
                font-family: var(--font-serif)  →  Fraunces Variable
                font-size: clamp(2rem, 5vw, 3rem)
                Kata biasa: color --color-text, weight normal
                <em>: font-style italic, color --color-accent,
                      font-variation-settings "opsz" 9, "SOFT" 100
            -->
            <h1 class="hero-heading">
              Engineer <em>by day,</em><br />
              Illustrator <em>by passion,</em><br />
              Family man <em>by purpose.</em>
            </h1>

            <p class="hero-lead">
              Saya percaya pada pertemuan antara struktur dan jiwa — membangun
              sistem yang skalabel sambil merajut cerita yang beresonansi.
              Pertumbuhan saya tidak hanya diukur dari commit, tetapi dari
              jembatan yang saya bangun antara teknologi dan emosi manusia.
            </p>

            <div class="hero-accent-bar" aria-hidden="true"></div>

            <div class="hero-actions">
              <a href="/work" class="btn-primary">Lihat karya</a>
              <a href="/about" class="btn-ghost">Tentang saya</a>
            </div>
          </div>

          <div class="hero-deco" aria-hidden="true">
            <span class="hero-deco-word">craft</span>
          </div>
        </div>

        <div class="scroll-hint" aria-hidden="true">
          <span class="scroll-hint-label">scroll</span>
          <div class="scroll-hint-line"></div>
        </div>
      </section>

      <!-- ══════════════════════════════
           SECTION 1 — SELECTED WORKS
           Style persis dari code.html
      ══════════════════════════════ -->
      <section class="snap-section section--works" id="s1" data-index="1">
        <div class="works-inner">
          <div class="works-header">
            <p class="works-eyebrow">SELECTED WORKS</p>
            <span class="works-year">2023 — {year}</span>
          </div>

          <!-- Zero-gap grid: 8fr feature + 4fr sidebar stack -->
          <div class="works-grid">
            <!-- Large Feature -->
            <div class="works-feature">
              {
                featuredWork[0] ? (
                  <a href={`/work/${featuredWork[0].id}`} class="grid-cell">
                    {featuredWork[0].data.cover ? (
                      <img
                        src={featuredWork[0].data.cover}
                        alt={
                          featuredWork[0].data.coverAlt ??
                          featuredWork[0].data.title
                        }
                        loading="eager"
                        decoding="async"
                      />
                    ) : (
                      <div class="grid-noimage">
                        <span>{featuredWork[0].data.title.charAt(0)}</span>
                      </div>
                    )}
                  </a>
                ) : (
                  <div class="grid-cell grid-cell--placeholder">
                    <div class="grid-noimage">
                      <span>A</span>
                    </div>
                  </div>
                )
              }
            </div>

            <!-- Sidebar Stack -->
            <div class="works-stack">
              {
                featuredWork[1] ? (
                  <a href={`/work/${featuredWork[1].id}`} class="grid-cell">
                    {featuredWork[1].data.cover ? (
                      <img
                        src={featuredWork[1].data.cover}
                        alt={
                          featuredWork[1].data.coverAlt ??
                          featuredWork[1].data.title
                        }
                        loading="lazy"
                        decoding="async"
                      />
                    ) : (
                      <div class="grid-noimage">
                        <span>{featuredWork[1].data.title.charAt(0)}</span>
                      </div>
                    )}
                  </a>
                ) : (
                  <div class="grid-cell grid-cell--placeholder">
                    <div class="grid-noimage">
                      <span>B</span>
                    </div>
                  </div>
                )
              }

              {
                featuredWork[2] ? (
                  <a href={`/work/${featuredWork[2].id}`} class="grid-cell">
                    {featuredWork[2].data.cover ? (
                      <img
                        src={featuredWork[2].data.cover}
                        alt={
                          featuredWork[2].data.coverAlt ??
                          featuredWork[2].data.title
                        }
                        loading="lazy"
                        decoding="async"
                      />
                    ) : (
                      <div class="grid-noimage">
                        <span>{featuredWork[2].data.title.charAt(0)}</span>
                      </div>
                    )}
                  </a>
                ) : (
                  <div class="grid-cell grid-cell--placeholder">
                    <div class="grid-noimage">
                      <span>C</span>
                    </div>
                  </div>
                )
              }
            </div>
          </div>
        </div>
      </section>

      <!-- ══════════════════════════════
           SECTION 2 — RECENT REFLECTIONS
           Style persis dari code.html
      ══════════════════════════════ -->
      <section class="snap-section section--blog" id="s2" data-index="2">
        <div class="blog-inner">
          <p class="blog-eyebrow">RECENT REFLECTIONS</p>

          <div class="blog-grid">
            {
              latestPosts.length === 0 ? (
                <>
                  <article class="blog-article">
                    <div class="article-meta">
                      <span class="article-cat">SELF-DEVELOPMENT</span>
                    </div>
                    <h4 class="article-title">
                      The Art of Deliberate Practice in Engineering
                    </h4>
                    <p class="article-excerpt">
                      Bagaimana memperlakukan arsitektur software layaknya
                      masterclass ilustrasi dapat mengubah cara kita mendekati
                      pemecahan masalah yang kompleks...
                    </p>
                    <span class="article-cta">
                      READ JOURNAL
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                      >
                        <path d="M5 12h14M13 6l6 6-6 6" />
                      </svg>
                    </span>
                  </article>

                  <article class="blog-article">
                    <div class="article-meta">
                      <span class="article-cat">PHILOSOPHY</span>
                    </div>
                    <h4 class="article-title">
                      Finding Stillness in the Middle of the Grind
                    </h4>
                    <p class="article-excerpt">
                      Refleksi tentang mempertahankan output kreatif sembari
                      menjalani karier engineering penuh waktu dan kekacauan
                      indah kehidupan keluarga...
                    </p>
                    <span class="article-cta">
                      READ JOURNAL
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                      >
                        <path d="M5 12h14M13 6l6 6-6 6" />
                      </svg>
                    </span>
                  </article>
                </>
              ) : (
                latestPosts.map((post) => (
                  <article class="blog-article">
                    <div class="article-meta">
                      <span class="article-cat">
                        {categoryLabel[post.data.category]?.toUpperCase()}
                      </span>
                    </div>
                    <h4 class="article-title">{post.data.title}</h4>
                    <p class="article-excerpt">{post.data.description}</p>
                    <a href={`/blog/${post.id}`} class="article-cta">
                      READ JOURNAL
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                      >
                        <path d="M5 12h14M13 6l6 6-6 6" />
                      </svg>
                    </a>
                  </article>
                ))
              )
            }
          </div>

          <!-- Footer — persis dari code.html -->
          <footer class="blog-footer">
            <p class="blog-footer-copy">© {year} TEGUH SUWANDA</p>
            <div class="blog-footer-links">
              <a
                href="https://instagram.com/suwandateguh"
                target="_blank"
                rel="noopener">INSTAGRAM</a
              >
              <a
                href="https://github.com/909teguh"
                target="_blank"
                rel="noopener">GITHUB</a
              >
            </div>
          </footer>
        </div>
      </section>
    </div><!-- /snap-container -->

    <!-- Section dot navigator -->
    <nav class="section-dots" id="section-dots" aria-label="Section navigator">
      <button class="dot dot--active" data-target="0" aria-label="Hero"
      ></button>
      <button class="dot" data-target="1" aria-label="Works"></button>
      <button class="dot" data-target="2" aria-label="Blog"></button>
    </nav>
  </body>
</html>

<style>
  /* ══════════════════════════════════════════
     GLOBAL RESETS FOR HOME PAGE
  ══════════════════════════════════════════ */
  .home-body {
    /* Nav sudah sticky dari komponen Nav.astro (height 3.5rem) */
    /* Body harus non-scrollable; scroll hanya di snap-container */
    overflow: hidden;
    height: 100dvh;
    display: flex;
    flex-direction: column;
  }

  /* ══════════════════════════════════════════
     SNAP CONTAINER
     Mengisi sisa tinggi setelah Nav (3.5rem)
  ══════════════════════════════════════════ */
  .snap-container {
    flex: 1;
    min-height: 0; /* penting agar flex child bisa scroll */
    overflow-y: scroll;
    overflow-x: hidden;
    scroll-snap-type: y mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
  }
  .snap-container::-webkit-scrollbar {
    display: none;
  }

  /* ══════════════════════════════════════════
     SNAP SECTIONS — tiap section = 100% tinggi container
  ══════════════════════════════════════════ */
  .snap-section {
    scroll-snap-align: start;
    scroll-snap-stop: always;
    /* 100vh dikurangi tinggi Nav (3.5rem) */
    height: calc(100dvh - 3.5rem);
    width: 100%;
    display: flex;
    position: relative;
    /* Fade-in awal */
    opacity: 0;
    transform: translateY(12px);
    transition:
      opacity 0.5s ease,
      transform 0.5s ease;
  }
  .snap-section.in-view {
    opacity: 1;
    transform: translateY(0);
  }

  /* ══════════════════════════════════════════
     SECTION 0 — HERO
  ══════════════════════════════════════════ */
  .section--hero {
    background: var(--color-bg);
    align-items: center;
    justify-content: center;
  }

  .hero-layout {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 2rem;
    width: 100%;
    max-width: 72rem;
    padding: 0 4rem;
  }

  .hero-eyebrow {
    /* Sama persis dengan .intro-eyebrow di about.astro */
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin: 0 0 1rem;
  }

  /*
    TIPOGRAFI HERO — identik dengan .intro-heading di about.astro:
      font-family: var(--font-serif)  = Fraunces Variable
      font-size: clamp(2rem, 5vw, 3rem)
      line-height: 1.1
      letter-spacing: -0.02em
      color: var(--color-text)

    <em> identik dengan .intro-heading em di about.astro:
      font-style: italic
      color: var(--color-accent)
      font-variation-settings: "opsz" 9, "SOFT" 100
  */
  .hero-heading {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 5vw, 3rem);
    font-variation-settings: "opsz" 9;
    color: var(--color-text);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0 0 1.5rem;
  }
  .hero-heading em {
    font-style: italic;
    color: var(--color-accent);
    font-variation-settings:
      "opsz" 9,
      "SOFT" 100;
  }

  /* .intro-lead style dari about.astro */
  .hero-lead {
    font-size: 1.0625rem;
    color: var(--color-text-muted);
    line-height: 1.8;
    max-width: 46ch;
    margin: 0 0 2rem;
  }

  /* Garis oranye pendek */
  .hero-accent-bar {
    width: 2.5rem;
    height: 3px;
    background: var(--color-accent);
    border-radius: 99px;
    margin-bottom: 2rem;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }
  .btn-primary {
    display: inline-flex;
    align-items: center;
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.625rem 1.25rem;
    border-radius: 8px;
    background: var(--color-accent);
    color: #fff;
    transition: opacity 0.15s;
  }
  .btn-primary:hover {
    opacity: 0.85;
  }
  .btn-ghost {
    display: inline-flex;
    align-items: center;
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.625rem 1.25rem;
    border-radius: 8px;
    border: 1px solid var(--color-border);
    color: var(--color-text);
    transition: background 0.15s;
  }
  .btn-ghost:hover {
    background: var(--color-bg-subtle);
  }

  /* Dekorasi kata italic besar kanan */
  .hero-deco {
    flex-shrink: 0;
    user-select: none;
    padding-bottom: 0.5rem;
  }
  .hero-deco-word {
    font-family: var(--font-serif);
    font-size: clamp(5rem, 10vw, 9rem);
    font-style: italic;
    font-variation-settings:
      "opsz" 9,
      "SOFT" 100;
    color: var(--color-border);
    letter-spacing: -0.04em;
    line-height: 1;
    display: block;
  }

  /* Scroll hint bawah */
  .scroll-hint {
    position: absolute;
    bottom: 1.75rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
  }
  .scroll-hint-label {
    font-size: 0.625rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-border);
  }
  .scroll-hint-line {
    width: 1px;
    height: 2rem;
    background: linear-gradient(to bottom, var(--color-border), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
    transform-origin: top;
  }
  @keyframes scrollPulse {
    0%,
    100% {
      opacity: 0.3;
      transform: scaleY(0.5);
    }
    50% {
      opacity: 1;
      transform: scaleY(1);
    }
  }

  /* ══════════════════════════════════════════
     SECTION 1 — SELECTED WORKS
     Identik dengan code.html: zero-gap, grayscale→color hover
  ══════════════════════════════════════════ */
  .section--works {
    background: var(--color-bg);
    align-items: stretch;
    flex-direction: column;
  }

  .works-inner {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  /* Header row — persis code.html */
  .works-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    /* px-8 md:px-20 dari code.html */
    padding: 2.5rem 5rem 1.25rem;
    flex-shrink: 0;
  }
  .works-eyebrow {
    /* text-xs font-label uppercase tracking-[0.3em] text-on-surface-variant */
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }
  .works-year {
    /* text-xs font-label text-outline-variant italic */
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-style: italic;
    color: var(--color-text-muted);
    opacity: 0.5;
  }

  /* Grid: 12-col zero-gap — identik code.html grid-cols-12 gap-0 */
  .works-grid {
    display: grid;
    grid-template-columns: 8fr 4fr; /* md:col-span-8 + md:col-span-4 */
    gap: 0; /* ZERO GAP */
    flex: 1;
    min-height: 0;
    overflow: hidden;
  }

  .works-feature {
    overflow: hidden;
    height: 100%;
  }

  /* Sidebar stack — 2 equal rows */
  .works-stack {
    display: grid;
    grid-template-rows: 1fr 1fr;
    gap: 0; /* ZERO GAP */
    height: 100%;
  }

  /* Grid cell */
  .grid-cell {
    display: block;
    width: 100%;
    height: 100%;
    overflow: hidden;
    position: relative;
    background: var(--color-bg-subtle);
  }
  .grid-cell--placeholder {
    cursor: default;
  }

  /* Gambar — grayscale default, color on hover — identik code.html */
  .grid-cell img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: grayscale(100%);
    transition:
      filter 0.7s ease,
      transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    cursor: pointer;
  }
  .grid-cell:hover img {
    filter: grayscale(0%);
    transform: scale(1.03);
  }

  /* Placeholder tanpa gambar */
  .grid-noimage {
    width: 100%;
    height: 100%;
    min-height: 160px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg-subtle);
    font-family: var(--font-serif);
    font-size: 3.5rem;
    font-style: italic;
    color: var(--color-border);
  }

  /* ══════════════════════════════════════════
     SECTION 2 — RECENT REFLECTIONS
     Identik dengan code.html: 2-col, uppercase cat, "READ JOURNAL →"
  ══════════════════════════════════════════ */
  .section--blog {
    background: var(--color-bg);
    align-items: stretch;
    flex-direction: column;
  }

  .blog-inner {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    /* px-8 md:px-20 py-32 dari code.html */
    padding: 4rem 5rem 0;
    max-width: 100%;
  }

  /* Eyebrow — identik code.html */
  .blog-eyebrow {
    /* text-xs font-label uppercase tracking-[0.3em] text-on-surface-variant mb-16 */
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 4rem;
    flex-shrink: 0;
  }

  /* 2-col grid — identik code.html grid-cols-2 gap-16 md:gap-24 */
  .blog-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem 6rem;
    flex: 1;
  }

  /* Article — group hover pattern dari code.html */
  .blog-article {
    display: flex;
    flex-direction: column;
    gap: 0;
    text-decoration: none;
    color: inherit;
  }
  .blog-article a {
    text-decoration: none;
    color: inherit;
  }

  .article-meta {
    margin-bottom: 0.5rem;
  }

  /* Category — "text-xs font-label text-primary-container font-semibold" dari code.html */
  .article-cat {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  /* Title — "text-2xl font-bold text-on-surface group-hover:text-primary font-headline" */
  .article-title {
    font-family: var(--font-serif);
    font-size: clamp(1.25rem, 2vw, 1.5rem);
    font-variation-settings: "opsz" 9;
    font-weight: 500;
    color: var(--color-text);
    line-height: 1.3;
    margin-bottom: 1rem;
    transition: color 0.2s;
  }
  .blog-article:hover .article-title {
    color: var(--color-accent);
  }

  /* Excerpt — "text-on-surface-variant font-body leading-relaxed" */
  .article-excerpt {
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: 1.25rem;
    flex: 1;
  }

  /* CTA — "inline-flex items-center text-xs font-bold font-label tracking-widest" */
  .article-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.2s;
  }
  .blog-article:hover .article-cta {
    color: var(--color-accent);
  }
  .article-cta svg {
    transition: transform 0.2s;
  }
  .blog-article:hover .article-cta svg {
    transform: translateX(3px);
  }

  /* Footer — persis dari code.html */
  .blog-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem 0;
    margin-top: auto;
    flex-shrink: 0;
    border-top: 1px solid
      color-mix(in srgb, var(--color-border) 50%, transparent);
  }
  .blog-footer-copy {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: 0;
  }
  .blog-footer-links {
    display: flex;
    gap: 2rem;
  }
  .blog-footer-links a {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }
  .blog-footer-links a:hover {
    color: var(--color-accent);
  }

  /* ══ SECTION DOTS ══ */
  .section-dots {
    position: fixed;
    right: 1.25rem;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    z-index: 30;
  }
  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    border: none;
    background: var(--color-border);
    cursor: pointer;
    padding: 0;
    transition:
      background 0.25s,
      transform 0.25s;
  }
  .dot--active {
    background: var(--color-accent);
    transform: scale(1.4);
  }

  /* ══ RESPONSIVE ══ */
  @media (max-width: 640px) {
    .section-dots {
      display: none;
    }

    .snap-section {
      height: calc(100dvh - 3.5rem);
    }

    /* Hero */
    .hero-layout {
      grid-template-columns: 1fr;
      padding: 1.5rem 1.25rem;
      gap: 0;
    }
    .hero-deco {
      display: none;
    }
    .hero-heading {
      font-size: clamp(1.75rem, 8vw, 2.25rem);
    }
    .hero-lead {
      font-size: 0.9375rem;
      max-width: 100%;
    }
    .scroll-hint {
      display: none;
    }

    /* Works */
    .works-header {
      padding: 1.5rem 1.25rem 0.75rem;
    }
    .works-grid {
      grid-template-columns: 1fr;
      grid-template-rows: 2fr 1fr;
    }
    .works-stack {
      grid-template-rows: 1fr;
      grid-template-columns: 1fr 1fr;
    }

    /* Blog */
    .blog-inner {
      padding: 2rem 1.25rem 0;
    }
    .blog-eyebrow {
      margin-bottom: 1.75rem;
    }
    .blog-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
      overflow-y: auto;
    }
    .blog-footer {
      padding: 1rem 0;
    }
  }

  @media (min-width: 641px) and (max-width: 1024px) {
    .hero-layout {
      padding: 0 2.5rem;
    }
    .works-header {
      padding: 2rem 2.5rem 1rem;
    }
    .blog-inner {
      padding: 3rem 2.5rem 0;
    }
    .blog-grid {
      gap: 3rem 4rem;
    }
  }
</style>

<script>
  // ── Scroll snap logic ──
  const container = document.getElementById("snap-container")!;
  const sections = document.querySelectorAll<HTMLElement>(".snap-section");
  const dots = document.querySelectorAll<HTMLButtonElement>(".dot");

  function H() {
    return container.clientHeight;
  }

  function goTo(idx: number) {
    container.scrollTo({ top: idx * H(), behavior: "smooth" });
  }

  function onScroll() {
    const idx = Math.round(container.scrollTop / H());
    dots.forEach((d, i) => d.classList.toggle("dot--active", i === idx));
  }

  container.addEventListener("scroll", onScroll, { passive: true });
  dots.forEach((dot, i) => dot.addEventListener("click", () => goTo(i)));

  // Fade-in section pertama langsung
  sections[0].classList.add("in-view");

  // IntersectionObserver — fade-in saat section masuk viewport
  const obs = new IntersectionObserver(
    (entries) =>
      entries.forEach((e) => {
        if (e.isIntersecting) e.target.classList.add("in-view");
      }),
    { threshold: 0.3, root: container },
  );
  sections.forEach((s) => obs.observe(s));
</script>
