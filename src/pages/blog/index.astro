---
// src/pages/blog/index.astro
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog");
const posts = allPosts
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categories = ["all", "craft", "notes", "family"] as const;

const categoryLabel: Record<string, string> = {
  all: "All",
  craft: "Craft",
  notes: "Notes",
  family: "Family",
};

const categoryDesc: Record<string, string> = {
  craft: "Proses, teknik, dan refleksi tentang ilustrasi.",
  notes: "Catatan dari meja kerja — engineering, ide, dan hal sehari-hari.",
  family: "Jurnal sebagai suami dan ayah.",
};

const formatDate = (date: Date) =>
  date.toLocaleDateString("id-ID", {
    day: "numeric",
    month: "long",
    year: "numeric",
  });
---

<BaseLayout
  title="Blog"
  description="Tulisan tentang ilustrasi, engineering, dan hal-hal kecil yang membuat hidup bermakna."
>
  <div class="container">
    <!-- Header -->
    <header class="page-header">
      <div class="page-header-inner">
        <h1 class="page-title" id="page-title">Blog</h1>
        <p class="page-desc" id="page-desc">
          Tempat saya berpikir dengan keras — tentang gambar, kode, dan
          perjalanan menjadi manusia yang lebih baik.
        </p>
      </div>
      <div class="page-header-deco" aria-hidden="true">
        <span class="header-deco-word" id="deco-word">tulisan</span>
      </div>
    </header>

    <!-- Filter -->
    <div class="filter-bar" role="tablist">
      {
        categories.map((cat) => (
          <button
            class="filter-btn"
            data-filter={cat}
            role="tab"
            aria-selected={cat === "all" ? "true" : "false"}
          >
            {categoryLabel[cat]}
            {cat !== "all" && (
              <span class="filter-count" data-count-for={cat}>
                {posts.filter((p) => p.data.category === cat).length}
              </span>
            )}
          </button>
        ))
      }
    </div>

    <!-- Deskripsi kategori aktif -->
    <p class="category-desc" id="cat-desc">&nbsp;</p>

    <!-- List posts -->
    {
      posts.length === 0 ? (
        <div class="empty-state">
          <p>Belum ada tulisan. Sedang dimasak.</p>
        </div>
      ) : (
        <div class="posts-list" id="posts-list">
          {posts.map((post) => (
            <a
              href={`/blog/${post.id}`}
              class="post-item"
              data-category={post.data.category}
            >
              <div class="post-item-inner">
                <div class="post-top">
                  <span class={`post-cat post-cat--${post.data.category}`}>
                    {categoryLabel[post.data.category]}
                  </span>
                  <time
                    class="post-date"
                    datetime={post.data.pubDate.toISOString()}
                  >
                    {formatDate(post.data.pubDate)}
                  </time>
                </div>
                <h2 class="post-title">{post.data.title}</h2>
                <p class="post-desc">{post.data.description}</p>
                {post.data.tags.length > 0 && (
                  <div class="post-tags">
                    {post.data.tags.slice(0, 4).map((tag) => (
                      <span class="tag">#{tag}</span>
                    ))}
                  </div>
                )}
              </div>
              <span class="post-arrow" aria-hidden="true">
                →
              </span>
            </a>
          ))}
        </div>
      )
    }
  </div>
</BaseLayout>

<style>
  .container {
    max-width: 56rem;
    margin-inline: auto;
    padding-inline: 1.5rem;
  }

  /* Header */
  .page-header {
    padding-block: 4rem 2.5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2.5rem;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
  }

  .page-header-inner {
    flex: 1;
  }

  .page-title {
    font-size: clamp(2rem, 5vw, 3.25rem);
    margin: 0 0 1rem;
    color: var(--color-text);
    transition: opacity 0.2s;
  }

  .page-desc {
    font-size: 1rem;
    color: var(--color-text-muted);
    max-width: 52ch;
    margin: 0;
    line-height: 1.75;
    transition:
      opacity 0.2s,
      transform 0.25s;
  }

  .page-desc.is-transitioning {
    opacity: 0;
    transform: translateY(4px);
  }

  .page-header-deco {
    flex-shrink: 0;
    user-select: none;
    padding-bottom: 0.25rem;
  }

  .header-deco-word {
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-style: italic;
    font-variation-settings:
      "opsz" 9,
      "SOFT" 100;
    color: var(--color-border);
    letter-spacing: -0.03em;
    line-height: 1;
    transition:
      color 0.3s,
      opacity 0.3s;
    display: block;
  }

  .header-deco-word.deco--craft {
    color: var(--color-accent);
    opacity: 0.25;
  }
  .header-deco-word.deco--notes {
    color: var(--color-text-muted);
    opacity: 0.2;
  }
  .header-deco-word.deco--family {
    color: #16a34a;
    opacity: 0.25;
  }

  @media (max-width: 600px) {
    .page-header {
      flex-direction: column;
      gap: 0;
    }
    .page-header-deco {
      display: none;
    }
  }

  /* Filter */
  .filter-bar {
    display: flex;
    gap: 0.375rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }

  .filter-btn {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    padding: 0.375rem 0.875rem;
    border-radius: 99px;
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all 0.15s;
  }

  .filter-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .filter-btn[aria-selected="true"] {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #fff;
  }

  .filter-count {
    font-size: 0.7rem;
    background: color-mix(in srgb, currentColor 15%, transparent);
    border-radius: 99px;
    padding: 0.1rem 0.4rem;
    font-weight: 500;
  }

  .category-desc {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    font-style: italic;
    min-height: 1.4rem;
    margin: 0 0 2rem;
    transition: opacity 0.2s;
  }

  /* Posts list */
  .posts-list {
    display: flex;
    flex-direction: column;
    padding-bottom: 5rem;
  }

  .post-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding-block: 1.5rem;
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
    color: inherit;
    transition: background-color 0.15s;
    border-radius: 8px;
  }

  .post-item:first-child {
    border-top: 1px solid var(--color-border);
  }

  .post-item:hover {
    background-color: var(--color-bg-subtle);
    padding-inline: 1rem;
    margin-inline: -1rem;
  }

  .post-item.hidden {
    display: none;
  }

  .post-item-inner {
    flex: 1;
    min-width: 0;
  }

  .post-top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .post-cat {
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
  }

  .post-cat--notes {
    background: var(--color-bg-subtle);
    color: var(--color-text-muted);
  }
  .post-cat--craft {
    background: var(--color-accent-soft);
    color: var(--color-accent);
  }
  .post-cat--family {
    background: color-mix(in srgb, #16a34a 12%, transparent);
    color: #16a34a;
  }

  .post-date {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .post-title {
    font-size: 1.0625rem;
    font-weight: 500;
    margin: 0 0 0.375rem;
    color: var(--color-text);
    line-height: 1.4;
  }

  .post-desc {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-tags {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.75rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .post-arrow {
    font-size: 1.125rem;
    color: var(--color-border);
    flex-shrink: 0;
    transition:
      color 0.15s,
      transform 0.15s;
  }

  .post-item:hover .post-arrow {
    color: var(--color-accent);
    transform: translateX(3px);
  }

  /* Empty state */
  .empty-state {
    padding: 5rem 0;
    text-align: center;
    color: var(--color-text-muted);
    font-style: italic;
    font-family: var(--font-serif);
    font-size: 1.125rem;
  }
</style>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>(".filter-btn");
  const posts = document.querySelectorAll<HTMLElement>(".post-item");
  const catDesc = document.getElementById("cat-desc");
  const pageDesc = document.getElementById("page-desc");
  const decoWord = document.getElementById("deco-word");

  // Deskripsi filter bar (tetap sama)
  const filterDescs: Record<string, string> = {
    all: "",
    craft: "Proses, teknik, dan refleksi tentang ilustrasi.",
    notes: "Catatan dari meja kerja — engineering, ide, dan hal sehari-hari.",
    family: "Jurnal sebagai suami dan ayah.",
  };

  // Hook kalimat di header — berubah per kategori
  const headerHooks: Record<string, string> = {
    all: "Tempat saya berpikir dengan keras — tentang gambar, kode, dan perjalanan menjadi manusia yang lebih baik.",
    craft:
      "Di balik setiap ilustrasi ada pilihan yang tidak terlihat — soal warna, soal komposisi, soal apa yang ingin disampaikan. Saya tulis prosesnya di sini.",
    notes:
      "Pikiran-pikiran dari meja kerja. Kadang soal arsitektur sistem, kadang soal kenapa kopi sore terasa lebih baik dari kopi pagi.",
    family:
      "Ini bukan blog teknikal. Bagian ini adalah jurnal — catatan dari seorang ayah yang masih belajar hadir sepenuhnya di tengah jadwal yang tidak selalu berpihak.",
  };

  // Kata dekorasi dan class warna
  const decoConfig: Record<string, { word: string; cls: string }> = {
    all: { word: "tulisan", cls: "" },
    craft: { word: "proses", cls: "deco--craft" },
    notes: { word: "catatan", cls: "deco--notes" },
    family: { word: "jurnal", cls: "deco--family" },
  };

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const filter = btn.dataset.filter ?? "all";

      // Update aria-selected
      buttons.forEach((b) => b.setAttribute("aria-selected", "false"));
      btn.setAttribute("aria-selected", "true");

      // Filter post
      posts.forEach((post) => {
        const match = filter === "all" || post.dataset.category === filter;
        post.classList.toggle("hidden", !match);
      });

      // Update deskripsi filter bar
      if (catDesc) catDesc.textContent = filterDescs[filter] ?? "";

      // Animasi transisi header hook
      if (pageDesc) {
        pageDesc.classList.add("is-transitioning");
        setTimeout(() => {
          pageDesc.textContent = headerHooks[filter] ?? headerHooks.all;
          pageDesc.classList.remove("is-transitioning");
        }, 200);
      }

      // Update dekorasi kata
      if (decoWord) {
        const config = decoConfig[filter] ?? decoConfig.all;
        decoWord.textContent = config.word;
        decoWord.className = "header-deco-word";
        if (config.cls) decoWord.classList.add(config.cls);
      }
    });
  });
</script>
