---
// src/pages/blog/index.astro
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog");
const posts = allPosts
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categories = ["all", "craft", "notes", "family"] as const;
const postTypes  = ["all", "long", "quote", "image", "link"] as const;

const categoryLabel: Record<string, string> = {
  all: "Semua",
  craft: "Craft",
  notes: "Notes",
  family: "Family",
};

const typeLabel: Record<string, string> = {
  all:   "Semua",
  long:  "Artikel",
  quote: "Quote",
  image: "Foto",
  link:  "Link",
};

const typeIcon: Record<string, string> = {
  long:  "✦",
  quote: "❝",
  image: "◻",
  link:  "↗",
};

const formatDate = (date: Date) =>
  date.toLocaleDateString("id-ID", {
    day: "numeric",
    month: "long",
    year: "numeric",
  });

// Extract domain dari URL untuk link posts
const getDomain = (url: string) => {
  try {
    return new URL(url).hostname.replace("www.", "");
  } catch {
    return url;
  }
};
---

<BaseLayout
  title="Blog"
  description="Tulisan tentang ilustrasi, engineering, dan hal-hal kecil yang membuat hidup bermakna."
>
  <div class="container">

    <!-- ── HEADER ── -->
    <header class="page-header">
      <div class="page-header-inner">
        <h1 class="page-title">Blog</h1>
        <p class="page-desc" id="page-desc">
          Tempat saya berpikir dengan keras — tentang gambar, kode, dan
          perjalanan menjadi manusia yang lebih baik.
        </p>
      </div>
      <div class="page-header-deco" aria-hidden="true">
        <span class="header-deco-word" id="deco-word">tulisan</span>
      </div>
    </header>

    <!-- ── FILTER BAR ── -->
    <div class="filter-section">
      <!-- Filter by kategori -->
      <div class="filter-group">
        <span class="filter-group-label">Topik</span>
        <div class="filter-bar" role="tablist" id="cat-filter">
          {categories.map((cat) => (
            <button
              class="filter-btn"
              data-cat={cat}
              role="tab"
              aria-selected={cat === "all" ? "true" : "false"}
            >
              {categoryLabel[cat]}
            </button>
          ))}
        </div>
      </div>

      <!-- Filter by tipe post -->
      <div class="filter-group">
        <span class="filter-group-label">Format</span>
        <div class="filter-bar" role="tablist" id="type-filter">
          {postTypes.map((type) => (
            <button
              class="filter-btn filter-btn--type"
              data-type={type}
              role="tab"
              aria-selected={type === "all" ? "true" : "false"}
            >
              {type !== "all" && (
                <span class="type-icon" aria-hidden="true">{typeIcon[type]}</span>
              )}
              {typeLabel[type]}
            </button>
          ))}
        </div>
      </div>
    </div>

    <!-- ── FEED ── -->
    {posts.length === 0 ? (
      <div class="empty-state">
        <p>Belum ada tulisan. Sedang dimasak.</p>
      </div>
    ) : (
      <div class="feed" id="feed">
        {posts.map((post) => {
          const pt = post.data.postType ?? "long";
          return (
            <article
              class={`post-card post-card--${pt}`}
              data-cat={post.data.category}
              data-type={pt}
            >

              {/* ── LONG: artikel ── */}
              {pt === "long" && (
                <a href={`/blog/${post.id}`} class="post-link">
                  {post.data.cover && (
                    <div class="post-cover">
                      <img src={post.data.cover} alt={post.data.coverAlt ?? post.data.title} loading="lazy" />
                    </div>
                  )}
                  <div class="post-body">
                    <div class="post-meta-row">
                      <span class={`cat-badge cat-badge--${post.data.category}`}>
                        {categoryLabel[post.data.category]}
                      </span>
                      <time class="post-date" datetime={post.data.pubDate.toISOString()}>
                        {formatDate(post.data.pubDate)}
                      </time>
                    </div>
                    <h2 class="post-title">{post.data.title}</h2>
                    <p class="post-excerpt">{post.data.description}</p>
                    {post.data.tags.length > 0 && (
                      <div class="post-tags">
                        {post.data.tags.slice(0, 4).map((tag) => (
                          <span class="tag">#{tag}</span>
                        ))}
                      </div>
                    )}
                    <span class="read-more">Baca selengkapnya →</span>
                  </div>
                </a>
              )}

              {/* ── QUOTE ── */}
              {pt === "quote" && (
                <a href={`/blog/${post.id}`} class="post-link">
                  <div class="post-body">
                    <div class="post-meta-row">
                      <span class="type-pill type-pill--quote">
                        <span aria-hidden="true">❝</span> Quote
                      </span>
                      <time class="post-date" datetime={post.data.pubDate.toISOString()}>
                        {formatDate(post.data.pubDate)}
                      </time>
                    </div>
                    <blockquote class="quote-text">{post.data.title}</blockquote>
                    {(post.data.quoteAttribution || post.data.quoteSource) && (
                      <cite class="quote-cite">
                        {post.data.quoteAttribution}
                        {post.data.quoteSource && (
                          <span class="quote-source">, {post.data.quoteSource}</span>
                        )}
                      </cite>
                    )}
                    {post.data.description && post.data.description !== post.data.title && (
                      <p class="quote-comment">{post.data.description}</p>
                    )}
                  </div>
                </a>
              )}

              {/* ── IMAGE ── */}
              {pt === "image" && (
                <a href={`/blog/${post.id}`} class="post-link">
                  {post.data.image && (
                    <div class="post-image-wrap">
                      <img
                        src={post.data.image}
                        alt={post.data.imageAlt ?? post.data.title}
                        loading="lazy"
                        class="post-image"
                      />
                    </div>
                  )}
                  <div class="post-body post-body--image">
                    <div class="post-meta-row">
                      <span class="type-pill type-pill--image">
                        <span aria-hidden="true">◻</span> Foto
                      </span>
                      <time class="post-date" datetime={post.data.pubDate.toISOString()}>
                        {formatDate(post.data.pubDate)}
                      </time>
                    </div>
                    {post.data.imageCaption && (
                      <p class="image-caption">{post.data.imageCaption}</p>
                    )}
                    {post.data.description && (
                      <p class="post-excerpt">{post.data.description}</p>
                    )}
                  </div>
                </a>
              )}

              {/* ── LINK ── */}
              {pt === "link" && (
                <div class="post-body">
                  <div class="post-meta-row">
                    <span class="type-pill type-pill--link">
                      <span aria-hidden="true">↗</span> Link
                    </span>
                    <time class="post-date" datetime={post.data.pubDate.toISOString()}>
                      {formatDate(post.data.pubDate)}
                    </time>
                  </div>
                  <h2 class="post-title post-title--link">
                    <a
                      href={post.data.linkUrl}
                      target="_blank"
                      rel="noopener"
                      class="link-title-anchor"
                    >
                      {post.data.title}
                      <span class="link-domain">
                        {post.data.linkDomain ?? (post.data.linkUrl ? getDomain(post.data.linkUrl) : "")}
                      </span>
                    </a>
                  </h2>
                  {post.data.description && (
                    <p class="post-excerpt">{post.data.description}</p>
                  )}
                  {/* Komentar panjang — lihat di detail page */}
                  <a href={`/blog/${post.id}`} class="link-more">
                    Baca komentar →
                  </a>
                </div>
              )}

            </article>
          );
        })}
      </div>
    )}

  </div>
</BaseLayout>

<style>
  .container {
    max-width: 52rem;
    margin-inline: auto;
    padding-inline: 1.5rem;
  }

  /* ── Header ── */
  .page-header {
    padding-block: 4rem 2.5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2rem;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
  }

  .page-header-inner { flex: 1; }

  .page-title {
    font-size: clamp(2rem, 5vw, 3.25rem);
    margin: 0 0 1rem;
    color: var(--color-text);
  }

  .page-desc {
    font-size: 1rem;
    color: var(--color-text-muted);
    max-width: 52ch;
    margin: 0;
    line-height: 1.75;
    transition: opacity 0.2s, transform 0.25s;
  }

  .page-header-deco {
    flex-shrink: 0;
    user-select: none;
    padding-bottom: 0.25rem;
  }

  .header-deco-word {
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-style: italic;
    font-variation-settings: "opsz" 9, "SOFT" 100;
    color: var(--color-border);
    letter-spacing: -0.03em;
    line-height: 1;
    display: block;
    transition: color 0.3s, opacity 0.3s;
  }

  @media (max-width: 600px) {
    .page-header { flex-direction: column; gap: 0; }
    .page-header-deco { display: none; }
  }

  /* ── Filter Section ── */
  .filter-section {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding-bottom: 1.75rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2rem;
  }

  .filter-group {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .filter-group-label {
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-text-muted);
    width: 2.5rem;
    flex-shrink: 0;
  }

  .filter-bar {
    display: flex;
    gap: 0.375rem;
    flex-wrap: wrap;
  }

  .filter-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.8rem;
    padding: 0.3rem 0.75rem;
    border-radius: 99px;
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all 0.15s;
    font-family: var(--font-sans);
  }

  .filter-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .filter-btn[aria-selected="true"] {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #fff;
  }

  .type-icon {
    font-size: 0.75rem;
    opacity: 0.8;
  }

  /* ── Feed ── */
  .feed {
    display: flex;
    flex-direction: column;
    gap: 1px;
    padding-bottom: 6rem;
  }

  /* ── Base card ── */
  .post-card {
    border-bottom: 1px solid var(--color-border);
    transition: background-color 0.15s;
    border-radius: 8px;
  }

  .post-card:first-child {
    border-top: 1px solid var(--color-border);
  }

  .post-card.hidden {
    display: none;
  }

  .post-link {
    display: block;
    text-decoration: none;
    color: inherit;
    padding: 1.5rem 0;
    border-radius: 8px;
    transition: background-color 0.15s;
  }

  .post-card:hover > .post-link,
  .post-card:hover > .post-body {
    background-color: var(--color-bg-subtle);
    padding-inline: 1rem;
    margin-inline: -1rem;
  }

  .post-body {
    padding-block: 1.5rem;
  }

  /* ── Meta row ── */
  .post-meta-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .post-date {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-left: auto;
  }

  /* ── Category badge ── */
  .cat-badge {
    font-size: 0.68rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
  }

  .cat-badge--notes { background: var(--color-bg-subtle); color: var(--color-text-muted); }
  .cat-badge--craft { background: var(--color-accent-soft); color: var(--color-accent); }
  .cat-badge--family {
    background: color-mix(in srgb, #16a34a 12%, transparent);
    color: #16a34a;
  }

  /* ── Type pill ── */
  .type-pill {
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }

  .type-pill--quote {
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
    color: var(--color-accent);
    border: 1px solid color-mix(in srgb, var(--color-accent) 25%, transparent);
  }

  .type-pill--image {
    background: color-mix(in srgb, #7c3aed 10%, transparent);
    color: #7c3aed;
    border: 1px solid color-mix(in srgb, #7c3aed 25%, transparent);
  }

  :root.dark .type-pill--image {
    color: #a78bfa;
    background: color-mix(in srgb, #7c3aed 15%, transparent);
    border-color: color-mix(in srgb, #7c3aed 30%, transparent);
  }

  .type-pill--link {
    background: color-mix(in srgb, #0891b2 10%, transparent);
    color: #0891b2;
    border: 1px solid color-mix(in srgb, #0891b2 25%, transparent);
  }

  :root.dark .type-pill--link {
    color: #22d3ee;
    background: color-mix(in srgb, #0891b2 15%, transparent);
    border-color: color-mix(in srgb, #0891b2 30%, transparent);
  }

  /* ── Long post ── */
  .post-cover {
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 1.25rem;
    border: 1px solid var(--color-border);
    aspect-ratio: 16/7;
  }

  .post-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .post-title {
    font-size: 1.125rem;
    font-weight: 500;
    margin: 0 0 0.5rem;
    color: var(--color-text);
    line-height: 1.4;
    font-family: var(--font-serif);
    font-variation-settings: "opsz" 9;
  }

  .post-excerpt {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin: 0 0 0.875rem;
    line-height: 1.7;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-tags {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.875rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .read-more {
    font-size: 0.8125rem;
    color: var(--color-accent);
    font-weight: 500;
    transition: opacity 0.15s;
  }

  .post-link:hover .read-more { opacity: 0.75; }

  /* ── Quote card ── */
  .post-card--quote {
    position: relative;
    padding-left: 1.5rem;
  }

  .post-card--quote::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--color-accent);
    border-radius: 99px;
    opacity: 0.5;
  }

  .post-card--quote:hover::before {
    opacity: 1;
  }

  .quote-text {
    font-family: var(--font-serif);
    font-size: clamp(1.125rem, 2.5vw, 1.375rem);
    font-style: italic;
    font-variation-settings: "opsz" 9, "SOFT" 100;
    color: var(--color-text);
    line-height: 1.6;
    margin: 0 0 0.75rem;
    border: none;
    padding: 0;
  }

  .quote-cite {
    display: block;
    font-size: 0.8125rem;
    font-style: normal;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  .quote-cite::before { content: "— "; }

  .quote-source {
    font-style: italic;
    color: var(--color-text-muted);
  }

  .quote-comment {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.65;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-border);
  }

  /* ── Image card ── */
  .post-image-wrap {
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    margin-bottom: 0;
  }

  .post-image {
    width: 100%;
    height: auto;
    display: block;
    max-height: 480px;
    object-fit: cover;
    transition: transform 0.35s ease;
  }

  .post-card--image:hover .post-image {
    transform: scale(1.02);
  }

  .post-body--image { padding-top: 1rem; }

  .image-caption {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.9375rem;
    color: var(--color-text);
    margin: 0 0 0.5rem;
    line-height: 1.5;
  }

  /* ── Link card ── */
  .post-card--link .post-body {
    padding-block: 1.5rem;
  }

  .post-card--link:hover .post-body {
    background-color: var(--color-bg-subtle);
    padding-inline: 1rem;
    margin-inline: -1rem;
  }

  .post-title--link { margin-bottom: 0.25rem; }

  .link-title-anchor {
    display: flex;
    align-items: baseline;
    gap: 0.625rem;
    flex-wrap: wrap;
    text-decoration: none;
    color: var(--color-text);
    font-family: var(--font-serif);
    font-size: 1.0625rem;
    transition: color 0.15s;
  }

  .link-title-anchor:hover { color: var(--color-accent); }

  .link-domain {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    font-weight: 400;
    font-style: normal;
    padding: 0.15rem 0.5rem;
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    border-radius: 4px;
  }

  .link-more {
    display: inline-block;
    margin-top: 0.75rem;
    font-size: 0.8125rem;
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 500;
    transition: opacity 0.15s;
  }

  .link-more:hover { opacity: 0.75; }

  /* ── Empty state ── */
  .empty-state {
    padding: 5rem 0;
    text-align: center;
    color: var(--color-text-muted);
    font-style: italic;
    font-family: var(--font-serif);
    font-size: 1.125rem;
  }
</style>

<script>
  // ── State filter aktif ──
  let activeCat  = "all";
  let activeType = "all";

  function applyFilter() {
    const cards = document.querySelectorAll<HTMLElement>(".post-card");
    cards.forEach((card) => {
      const matchCat  = activeCat  === "all" || card.dataset.cat  === activeCat;
      const matchType = activeType === "all" || card.dataset.type === activeType;
      card.classList.toggle("hidden", !(matchCat && matchType));
    });
  }

  // ── Filter kategori ──
  const catBtns = document.querySelectorAll<HTMLButtonElement>("#cat-filter .filter-btn");
  catBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      activeCat = btn.dataset.cat ?? "all";
      catBtns.forEach((b) => b.setAttribute("aria-selected", "false"));
      btn.setAttribute("aria-selected", "true");
      applyFilter();
    });
  });

  // ── Filter tipe ──
  const typeBtns = document.querySelectorAll<HTMLButtonElement>("#type-filter .filter-btn");
  typeBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      activeType = btn.dataset.type ?? "all";
      typeBtns.forEach((b) => b.setAttribute("aria-selected", "false"));
      btn.setAttribute("aria-selected", "true");
      applyFilter();
    });
  });
</script>
