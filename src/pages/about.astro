---
// src/pages/about.astro
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
    title="About"
    description="Engineer by day, illustrator by passion, family man by purpose."
>
    <!-- ══ HERO ══ -->
    <section class="ab-hero">
        <div class="ab-hero-inner">
            <h1 class="ab-hero-heading">
                Just someone who likes building things,<br />
                <span class="ab-hero-heading-serif"
                    >with code and with hands.</span
                >
            </h1>
            <div class="ab-hero-body-grid">
                <div class="ab-hero-body-col">
                    <p class="ab-hero-lead">
                        Hi, I’m Teguh. I work as an engineer during the day, and
                        I draw whenever I can. I enjoy building things—sometimes
                        systems, sometimes illustrations. Lately, I’ve been
                        trying to do both with more intention.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- ══ THREE PILLARS — BENTO GRID ══ -->
    <section class="ab-pillars">
        <div class="ab-grid">
            <!-- 01 Engineer — text card -->
            <div class="ab-card ab-card--engineer">
                <div>
                    <span class="ab-eyebrow">01 — The Engineer</span>
                    <h2 class="ab-pillar-h">
                        Still learning, but I enjoy building things for the web.
                    </h2>
                    <p class="ab-pillar-body">
                        I’ve been working mostly with Laravel, building and
                        maintaining web applications. Lately, I’ve been trying
                        to get better at JavaScript and the frontend side of
                        things—still learning, still figuring things out.
                        Nothing too fancy, just trying to write code that works
                        and makes sense.
                    </p>
                </div>
                <div class="ab-tags">
                    <span class="ab-tag">Laravel</span>
                    <span class="ab-tag">JavaScript</span>
                </div>
            </div>

            <!-- 01 Engineer — image -->
            <div class="ab-card ab-card--img ab-card--eng-img">
                <img
                    src="https://lh3.googleusercontent.com/aida-public/AB6AXuBA3tXPwf2o9Pk83HdtIQcE3ivSyo4JEd6ZVvldxT_YeBaaakMjVyWvM0nXLFY4xJIcm0Cf5ZEBj28Gi63LGwFCdw6i1F8ol0NT8ODQEB-4CD7BuyaBbwUEp9Wvm8u1AD800YqD1gOTvjBre3MXt72rxufvpWw-MFo32FWGnc4StpfLcWrK9oCDZUXLSiT5MLxRpIVp8x6cLZVP57bP3N-y8bwc4wL0ViABFe1Q2QAOsjRn_IZzWrPjFJ5hQdbYBTvDWNNVyGKVF8RV"
                    alt="Technical engineering setup with clean lines"
                    class="ab-img"
                    loading="lazy"
                />
                <div class="ab-img-tint"></div>
            </div>

            <!-- 02 Illustrator — image -->
            <div class="ab-card ab-card--img ab-card--illus-img">
                <img
                    src="https://lh3.googleusercontent.com/aida-public/AB6AXuCFLu-j_x7SEP9mO6tSVjDrxDvK387cEAPURdJnNWjG9yfFbA1bnGq421z_lrfGLNByYfcZVY7AFt5dCGIFGnIdoNgTPBjKU917WuREqevs3QYBbH_bOrp36XI2quoLoSdUwwHi94cdHBamfYptOqWJWjd9ucaH39IVqtsD48yzXj890p6WJ2RZOTvtDPq9LjBdKg7bOBmRoa-XWnN_tJxZsribVGPTxSinAmLcMFx8xYDT833fvWwQHX15pcGTUSywV3XZKu5IO2CA"
                    alt="Detailed botanical illustration"
                    class="ab-img"
                    loading="lazy"
                />
            </div>

            <!-- 02 Illustrator — text card -->
            <div class="ab-card ab-card--illus">
                <span class="ab-eyebrow">02 — The Illustrator</span>
                <h2 class="ab-pillar-h ab-pillar-h--serif">
                    Observing the world, one line at a time.
                </h2>
                <p class="ab-pillar-body">
                    Drawing helps me slow down. It’s something I’ve spent more
                    time with, and feel more at home doing. I focus on texture,
                    light, and quiet details—things that don’t shout, but stay.
                </p>
            </div>

            <!-- 03 Family Man -->
            <div class="ab-card ab-card--family">
                <div class="ab-family-text">
                    <span class="ab-eyebrow">03 — Life Outside Work</span>
                    <h2 class="ab-pillar-h">Most of life happens here.</h2>
                    <p class="ab-pillar-body">
                        Outside of work and drawing, I spend most of my time
                        with my family. It’s not always balanced, and I’m still
                        figuring it out—but it’s the part of life I care about
                        the most.
                    </p>
                </div>
                <div class="ab-family-imgs">
                    <div class="ab-fimg ab-fimg--top">
                        <img
                            src="https://lh3.googleusercontent.com/aida-public/AB6AXuDq1xFUpWGlBMjXy-PGW6eGNIU0JxN1kgYD81DtbcisXfeoVG_PifLE5lSE3qtYIFsoJcxn7WBiYJUzpixQbHQYGXcxgwEFl5tSDJM2x1X-z_smBVJG-Yti4VSopDAOD_CcmC-8ZuE4pU5Yzw1Q_hC2FIOj508V9Ipme0EZcrfOpl2hgkOSdTafkz6nIZIEJ-8RXMBZptC58XIJjV3Y_8ylaovVjWreM_oWta4_-uAUtWvAhHgCjecGUYO1FhlWRgBJ-782UfNJNF4w"
                            alt="Warm family gathering scene"
                            loading="lazy"
                        />
                    </div>
                    <div class="ab-fimg ab-fimg--bottom">
                        <img
                            src="https://lh3.googleusercontent.com/aida-public/AB6AXuDntmhPm31Lg7ZunvKBypvawZ9ZYnRu_RxiKkWQOvp2pqL-RzIWBz1teUD1MlanGysMJoGgk-oNFoh3GF7CB4S9AnBEBmXUDLNgeYDAaOOh4hdlDkEglRewI8IQkauIi8WznRNgrw0yZ7Srr4mLhOyaQpdla_VRb5bRRyMtdq5Zd0xde93I6sDom3Uf4qv1tH9mvrju1znEesZHoxUnIasl_wmRnZNrskzOfk8WnnQpanZYiyaGn_6KBTgGOAL8rckidn23KFOT6aAi"
                            alt="Peaceful morning light"
                            loading="lazy"
                        />
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ══ PHILOSOPHY ══ -->
    <section class="ab-philosophy">
        <div class="ab-philosophy-inner">
            <span class="ab-phil-eyebrow">The Philosophy</span>
            <blockquote class="ab-quote">
                "I’m just trying to build things that make sense— in code, in
                art, and in life."
            </blockquote>
            <div class="ab-rule" aria-hidden="true"></div>
            <p class="ab-phil-body">
                Nothing complicated. Just something I try to live by.
            </p>
        </div>
    </section>

    <!-- ══ CTA ══ -->
    <section class="ab-cta-wrap">
        <div class="ab-cta">
            <div class="ab-cta-text">
                <h3 class="ab-cta-h">Have something in mind?</h3>
                <p class="ab-cta-sub">
                    I’m always open to ideas, small conversations, or just
                    connecting with like-minded people.
                </p>
            </div>
            <a href="mailto:[EMAIL_ADDRESS]" class="ab-cta-btn">Let’s talk</a>
        </div>
    </section>
</BaseLayout>

<style>
    /* ══════════════════════════════════════════
     GOOGLE FONTS
  ══════════════════════════════════════════ */
    @import url("https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;800&family=Newsreader:ital,opsz,wght@1,6..72,400;1,6..72,600&display=swap");

    /* ══════════════════════════════════════════
     DESIGN TOKENS
  ══════════════════════════════════════════ */
    :root {
        --ab-surface: #fcf9f8;
        --ab-surface-low: #f6f3f2;
        --ab-surface-cont: #f0edec;
        --ab-surface-high: #ebe7e7;
        --ab-surface-highest: #e5e2e1;
        --ab-surface-lowest: #ffffff;
        --ab-on-bg: #1c1b1b;
        --ab-on-surface-var: #554335;
        --ab-outline-var: #dbc2b0;
        --ab-primary: #8f4e00;
        --ab-primary-fixed: #ffdcc2;
        --ab-on-primary: #ffffff;
        --ab-f-head: "Inter", sans-serif;
        --ab-f-body: "Newsreader", serif;
    }

    :root.dark {
        --ab-surface: #141412;
        --ab-surface-low: #1e1d1a;
        --ab-surface-cont: #252320;
        --ab-surface-high: #2a2825;
        --ab-surface-highest: #302e2b;
        --ab-surface-lowest: #232220;
        --ab-on-bg: #f5f3ee;
        --ab-on-surface-var: #c9b8ac;
        --ab-outline-var: #4a3828;
        --ab-primary: #e28112;
        --ab-primary-fixed: #3d2200;
    }

    * {
        box-sizing: border-box;
    }

    /* ══════════════════════════════════════════
     HERO
  ══════════════════════════════════════════ */
    .ab-hero {
        background: var(--ab-surface);
        padding: 8rem 5rem 5rem;
    }

    .ab-hero-inner {
        max-width: 72rem;
    }

    .ab-hero-heading {
        font-family: var(--ab-f-head);
        font-size: clamp(2.25rem, 5.5vw, 3.75rem);
        font-weight: 800;
        letter-spacing: -0.03em;
        line-height: 1.1;
        color: var(--ab-on-bg);
        margin: 0 0 2rem;
    }

    .ab-hero-heading-serif {
        font-family: var(--ab-f-body);
        font-style: italic;
        font-weight: 400;
        color: var(--ab-primary);
        display: block;
    }

    .ab-hero-body-grid {
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        gap: 2rem;
    }

    .ab-hero-body-col {
        grid-column: span 7;
    }

    .ab-hero-lead {
        font-family: var(--ab-f-body);
        font-style: italic;
        font-size: 1.25rem;
        line-height: 1.75;
        color: var(--ab-on-surface-var);
        margin: 0;
    }

    /* ══════════════════════════════════════════
     PILLARS — 12-COL BENTO GRID
  ══════════════════════════════════════════ */
    .ab-pillars {
        background: var(--ab-surface-low);
        padding: 5rem;
    }

    .ab-grid {
        max-width: 80rem;
        margin-inline: auto;
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        gap: 2rem;
    }

    /* ── Card base ── */
    .ab-card {
        border-radius: 0.5rem;
        overflow: hidden;
    }

    /* ── Image cards ── */
    .ab-card--img {
        position: relative;
    }

    .ab-img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition: transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    .ab-card--img:hover .ab-img {
        transform: scale(1.06);
    }

    .ab-img-tint {
        position: absolute;
        inset: 0;
        background: rgba(143, 78, 0, 0.2);
        mix-blend-mode: multiply;
        pointer-events: none;
    }

    /* ── 01 Engineer text ── */
    .ab-card--engineer {
        grid-column: span 8;
        background: var(--ab-surface-lowest);
        padding: 3rem;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        min-height: 400px;
    }

    /* ── 01 Engineer image ── */
    .ab-card--eng-img {
        grid-column: span 4;
        min-height: 260px;
    }

    /* ── 02 Illustrator image ── */
    .ab-card--illus-img {
        grid-column: span 5;
        min-height: 500px;
    }

    /* ── 02 Illustrator text ── */
    .ab-card--illus {
        grid-column: span 7;
        background: var(--ab-surface-highest);
        padding: 3rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    /* ── 03 Family Man ── */
    .ab-card--family {
        grid-column: span 12;
        display: flex;
        align-items: center;
        gap: 3rem;
        margin-top: 1rem;
        background: transparent;
        border-radius: 0;
    }

    .ab-family-text {
        flex: 1;
    }

    .ab-family-imgs {
        flex: 1;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .ab-fimg {
        border-radius: 0.5rem;
        overflow: hidden;
        height: 16rem;
    }

    .ab-fimg img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .ab-fimg--bottom {
        margin-top: 2rem;
    }

    /* ── Shared text styles ── */
    .ab-eyebrow {
        font-family: var(--ab-f-head);
        font-size: 0.75rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        color: var(--ab-primary);
        display: block;
        margin-bottom: 1.5rem;
    }

    .ab-pillar-h {
        font-family: var(--ab-f-head);
        font-size: clamp(1.5rem, 2.5vw, 2.25rem);
        font-weight: 700;
        color: var(--ab-on-bg);
        line-height: 1.2;
        letter-spacing: -0.025em;
        margin: 0 0 1.5rem;
    }

    .ab-pillar-h--serif {
        font-family: var(--ab-f-body);
        font-style: italic;
        font-weight: 400;
        letter-spacing: -0.01em;
    }

    .ab-pillar-body {
        font-family: var(--ab-f-body);
        font-size: 1.0625rem;
        line-height: 1.75;
        color: var(--ab-on-surface-var);
        max-width: 52ch;
        margin: 0;
    }

    .ab-tags {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        margin-top: 2rem;
    }

    .ab-tag {
        font-family: var(--ab-f-head);
        font-size: 0.75rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        padding: 0.25rem 0.75rem;
        background: var(--ab-surface-cont);
        color: var(--ab-on-surface-var);
        border-radius: 0.25rem;
    }

    /* ══════════════════════════════════════════
     PHILOSOPHY
  ══════════════════════════════════════════ */
    .ab-philosophy {
        background: var(--ab-surface);
        padding: 8rem 5rem;
    }

    .ab-philosophy-inner {
        max-width: 48rem;
        margin-inline: auto;
        text-align: center;
    }

    .ab-phil-eyebrow {
        font-family: var(--ab-f-head);
        font-size: 0.75rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.4em;
        color: var(--ab-primary);
        display: block;
        margin-bottom: 2.5rem;
    }

    .ab-quote {
        font-family: var(--ab-f-body);
        font-style: italic;
        font-size: clamp(1.5rem, 3vw, 2.5rem);
        line-height: 1.35;
        color: var(--ab-on-bg);
        margin: 0 0 2.5rem;
        border: none;
        padding: 0;
    }

    .ab-rule {
        width: 3rem;
        height: 1px;
        background: var(--ab-outline-var);
        margin-inline: auto;
        margin-bottom: 2.5rem;
    }

    .ab-phil-body {
        font-family: var(--ab-f-body);
        font-size: 1.0625rem;
        line-height: 1.9;
        color: var(--ab-on-surface-var);
        margin: 0;
    }

    .ab-phil-body strong {
        font-weight: 600;
        font-style: italic;
        color: var(--ab-on-bg);
    }

    /* ══════════════════════════════════════════
     CTA
  ══════════════════════════════════════════ */
    .ab-cta-wrap {
        padding: 0 5rem 8rem;
        background: var(--ab-surface);
    }

    .ab-cta {
        background: var(--ab-primary);
        border-radius: 0.75rem;
        padding: 4rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 2rem;
        flex-wrap: wrap;
    }

    .ab-cta-h {
        font-family: var(--ab-f-head);
        font-size: clamp(1.5rem, 2.5vw, 2rem);
        font-weight: 700;
        color: var(--ab-on-primary);
        letter-spacing: -0.02em;
        margin: 0 0 0.5rem;
    }

    .ab-cta-sub {
        font-family: var(--ab-f-body);
        font-style: italic;
        font-size: 1rem;
        color: rgba(255, 255, 255, 0.8);
        margin: 0;
        line-height: 1.6;
    }

    .ab-cta-btn {
        font-family: var(--ab-f-head);
        font-size: 0.875rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--ab-primary);
        background: var(--ab-surface-lowest);
        padding: 1rem 2.5rem;
        border-radius: 0.5rem;
        text-decoration: none;
        flex-shrink: 0;
        white-space: nowrap;
        transition:
            transform 0.15s ease,
            opacity 0.15s ease;
        display: inline-block;
    }

    .ab-cta-btn:hover {
        transform: scale(1.02);
    }
    .ab-cta-btn:active {
        transform: scale(0.98);
    }

    /* ══════════════════════════════════════════
     RESPONSIVE
  ══════════════════════════════════════════ */

    /* Tablet ≤ 1024px */
    @media (max-width: 1024px) {
        .ab-hero,
        .ab-pillars,
        .ab-philosophy,
        .ab-cta-wrap {
            padding-inline: 2.5rem;
        }

        .ab-card--engineer {
            grid-column: span 12;
            min-height: auto;
        }
        .ab-card--eng-img {
            grid-column: span 12;
            min-height: 320px;
        }
        .ab-card--illus-img {
            grid-column: span 12;
            min-height: 380px;
        }
        .ab-card--illus {
            grid-column: span 12;
        }

        .ab-fimg {
            height: 12rem;
        }
    }

    /* Mobile ≤ 640px */
    @media (max-width: 640px) {
        .ab-hero {
            padding: 5rem 1.25rem 3rem;
        }

        .ab-hero-body-col {
            grid-column: span 12;
        }

        .ab-hero-lead {
            font-size: 1rem;
        }

        .ab-pillars {
            padding: 2.5rem 1.25rem;
        }

        .ab-grid {
            gap: 0.875rem;
        }

        .ab-card--engineer,
        .ab-card--eng-img,
        .ab-card--illus-img,
        .ab-card--illus,
        .ab-card--family {
            grid-column: span 12;
        }

        .ab-card--engineer {
            padding: 1.75rem;
            min-height: auto;
        }

        .ab-card--illus {
            padding: 1.75rem;
        }

        .ab-card--eng-img {
            min-height: 240px;
        }
        .ab-card--illus-img {
            min-height: 280px;
        }

        /* Family: stack vertically */
        .ab-card--family {
            flex-direction: column;
            gap: 1.5rem;
        }

        .ab-family-imgs {
            grid-template-columns: 1fr 1fr;
            gap: 0.625rem;
        }

        .ab-fimg {
            height: 9rem;
        }

        .ab-fimg--bottom {
            margin-top: 0.75rem;
        }

        .ab-philosophy {
            padding: 4rem 1.25rem;
        }

        .ab-cta-wrap {
            padding: 0 1.25rem 4rem;
        }

        .ab-cta {
            padding: 2rem 1.5rem;
            flex-direction: column;
            align-items: flex-start;
            border-radius: 0.5rem;
            gap: 1.5rem;
        }

        .ab-cta-btn {
            width: 100%;
            text-align: center;
        }
    }
</style>
