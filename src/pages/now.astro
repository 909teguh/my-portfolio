---
// src/pages/now.astro
import { getCollection, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

// Ambil satu-satunya entry di collection 'now'
const entries = await getCollection("now");
const entry = entries[0];

if (!entry) {
  return Astro.redirect("/");
}

const { Content } = await render(entry);
const { lastUpdated, projects, focus } = entry.data;

const formatDate = (date: Date) =>
  date.toLocaleDateString("id-ID", {
    day: "numeric",
    month: "long",
    year: "numeric",
  });
---

<BaseLayout
  title="Now"
  description="Apa yang sedang saya kerjakan dan fokuskan — diperbarui secara berkala."
>
  <div class="container">

    <!-- ── HEADER ── -->
    <header class="page-header">
      <div class="header-left">
        <p class="header-eyebrow">
          <span class="dot" aria-hidden="true"></span>
          Diperbarui {formatDate(lastUpdated)}
        </p>
        <h1 class="page-title">Now</h1>
        <div class="page-intro">
          <Content />
        </div>
      </div>
      <div class="header-deco" aria-hidden="true">
        <span class="deco-text">sekarang</span>
      </div>
    </header>

    <!-- ── PROJECTS ── -->
    {projects.length > 0 && (
      <section class="now-section">
        <div class="section-label">
          <span class="label-icon" aria-hidden="true">◈</span>
          <h2 class="section-title">Sedang dikerjakan</h2>
        </div>
        <div class="projects-list">
          {projects.map((p) => (
            <div class="project-item">
              <div class="project-top">
                <p class="project-title">{p.title}</p>
                <span
                  class={`status-badge status-badge--${p.status === "aktif" ? "active" : "slow"}`}
                  aria-label={`Status: ${p.status}`}
                >
                  {p.status}
                </span>
              </div>
              <p class="project-desc">{p.desc}</p>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- ── FOCUS ── -->
    {focus.length > 0 && (
      <section class="now-section">
        <div class="section-label">
          <span class="label-icon" aria-hidden="true">◉</span>
          <h2 class="section-title">Fokus & tujuan</h2>
        </div>
        <div class="focus-list">
          {focus.map((f, i) => (
            <div class="focus-item">
              <span class="focus-num" aria-hidden="true">0{i + 1}</span>
              <div class="focus-content">
                <p class="focus-area">{f.area}</p>
                <p class="focus-desc">{f.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- ── FOOTER NOTE ── -->
    <aside class="footer-note">
      <p>
        Ingin ngobrol tentang salah satu hal di atas?
        <a href="/about" class="inline-link">Jangan sungkan menyapa →</a>
      </p>
    </aside>

  </div>
</BaseLayout>

<style>
  .container {
    max-width: 52rem;
    margin-inline: auto;
    padding-inline: 1.5rem;
    padding-bottom: 6rem;
  }

  /* ── Header ── */
  .page-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 2rem;
    padding-block: 4rem 3rem;
    border-bottom: 1px solid var(--color-border);
  }

  .header-left {
    flex: 1;
    min-width: 0;
  }

  .header-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    letter-spacing: 0.03em;
    margin: 0 0 1rem;
  }

  /* Pulsing green dot */
  .dot {
    display: inline-block;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background-color: #22c55e;
    box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.4);
    animation: pulse 2.5s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes pulse {
    0%   { box-shadow: 0 0 0 0   rgba(34, 197, 94, 0.4); }
    70%  { box-shadow: 0 0 0 6px rgba(34, 197, 94, 0); }
    100% { box-shadow: 0 0 0 0   rgba(34, 197, 94, 0); }
  }

  .page-title {
    font-size: clamp(2.5rem, 6vw, 3.5rem);
    margin: 0 0 1.25rem;
    color: var(--color-text);
    line-height: 1;
  }

  /* Konten dari MDX (paragraf intro) */
  .page-intro {
    font-size: 1rem;
    color: var(--color-text-muted);
    line-height: 1.8;
    max-width: 52ch;
  }

  .page-intro :global(p) {
    margin: 0;
  }

  .page-intro :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: opacity 0.15s;
  }

  .page-intro :global(a:hover) {
    opacity: 0.75;
  }

  /* Dekorasi vertikal */
  .header-deco {
    flex-shrink: 0;
    padding-top: 0.5rem;
    user-select: none;
  }

  .deco-text {
    display: block;
    font-family: var(--font-serif);
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-style: italic;
    font-variation-settings: "opsz" 9, "SOFT" 100;
    color: var(--color-border);
    letter-spacing: -0.03em;
    line-height: 1;
    writing-mode: vertical-rl;
    text-orientation: mixed;
    opacity: 0.6;
  }

  /* ── Sections ── */
  .now-section {
    padding-block: 3rem;
    border-bottom: 1px solid var(--color-border);
  }

  .section-label {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    margin-bottom: 1.75rem;
  }

  .label-icon {
    color: var(--color-accent);
    font-size: 0.875rem;
    line-height: 1;
    flex-shrink: 0;
  }

  .section-title {
    font-size: 0.75rem;
    font-weight: 500;
    font-family: var(--font-sans);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin: 0;
  }

  /* ── Projects ── */
  .projects-list {
    display: flex;
    flex-direction: column;
  }

  .project-item {
    padding-block: 1.25rem;
    border-bottom: 1px solid var(--color-border);
  }

  .project-item:first-child { padding-top: 0; }
  .project-item:last-child  { border-bottom: none; padding-bottom: 0; }

  .project-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.375rem;
  }

  .project-title {
    font-size: 1rem;
    font-weight: 500;
    margin: 0;
    color: var(--color-text);
  }

  .project-desc {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.7;
    max-width: 56ch;
  }

  .status-badge {
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.2rem 0.6rem;
    border-radius: 99px;
    flex-shrink: 0;
    white-space: nowrap;
  }

  .status-badge--active {
    background: color-mix(in srgb, #22c55e 12%, transparent);
    color: #16a34a;
  }

  :root.dark .status-badge--active {
    background: color-mix(in srgb, #22c55e 15%, transparent);
    color: #4ade80;
  }

  .status-badge--slow {
    background: var(--color-bg-subtle);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
  }

  /* ── Focus ── */
  .focus-list {
    display: flex;
    flex-direction: column;
  }

  .focus-item {
    display: grid;
    grid-template-columns: 2.5rem 1fr;
    gap: 1.25rem;
    padding-block: 1.5rem;
    border-bottom: 1px solid var(--color-border);
    align-items: start;
  }

  .focus-item:first-child { padding-top: 0; }
  .focus-item:last-child  { border-bottom: none; padding-bottom: 0; }

  .focus-num {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.875rem;
    color: var(--color-accent);
    opacity: 0.5;
    padding-top: 0.2rem;
  }

  .focus-area {
    font-size: 1rem;
    font-weight: 500;
    margin: 0 0 0.375rem;
    color: var(--color-text);
  }

  .focus-desc {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.7;
    max-width: 52ch;
  }

  /* ── Footer note ── */
  .footer-note {
    margin-top: 3rem;
    padding: 1.25rem 1.5rem;
    border-radius: 10px;
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
  }

  .footer-note p {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.75;
  }

  .inline-link {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: opacity 0.15s;
  }

  .inline-link:hover { opacity: 0.75; }

  /* ── Responsive ── */
  @media (max-width: 600px) {
    .page-header {
      flex-direction: column;
    }

    .header-deco { display: none; }

    .focus-item {
      grid-template-columns: 1fr;
      gap: 0.375rem;
    }

    .focus-num { padding-top: 0; }
  }
</style>
