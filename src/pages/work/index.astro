---
// src/pages/work/index.astro
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const allWork = await getCollection("work");
const work = allWork.sort((a, b) => a.data.order - b.data.order);

const types = ["all", ...new Set(work.map((w) => w.data.type))];

const typeLabel: Record<string, string> = {
  all: "Everything",
  illustration: "Drawings",
  commission: "Commission",
  generative: "Generative",
  other: "Other",
};

// Aspect ratio hints per karya — fallback ke 1/1 kalau tidak ada cover
// Grid row span dihitung di client dari naturalHeight/naturalWidth gambar
---

<BaseLayout
  title="Work"
  description="Kumpulan karya ilustrasi — personal, commission, dan eksperimen generatif."
>
  <div class="container">
    <!-- Header -->
    <header class="page-header">
      <h1 class="page-title">Things I’ve Built</h1>
      <p class="page-desc">
        Things I made in between—late nights, quiet weekends, and moments I tried
        to hold onto.
      </p>
    </header>

    <!-- Filter tabs -->
    <div class="filter-bar" role="tablist" aria-label="Filter karya">
      {
        types.map((type) => (
          <button
            class="filter-btn"
            data-filter={type}
            role="tab"
            aria-selected={type === "all" ? "true" : "false"}
          >
            {typeLabel[type] ?? type}
          </button>
        ))
      }
    </div>

    <!-- Work Grid -->
    {
      work.length === 0 ? (
        <div class="empty-state">
          <p>Karya sedang dalam perjalanan. Nantikan.</p>
        </div>
      ) : (
        <div class="work-grid" id="work-grid">
          {work.map((item, i) => (
            <a
              href={`/work/${item.id}`}
              class="work-card"
              data-type={item.data.type}
              data-index={i}
              aria-label={item.data.title}
            >
              {item.data.cover ? (
                <img
                  class="work-card__img"
                  src={item.data.cover}
                  alt={item.data.coverAlt ?? item.data.title}
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <div class="work-card__noimage">
                  <span>{item.data.title.charAt(0)}</span>
                </div>
              )}

              <div class="work-card__overlay" aria-hidden="true">
                <div class="work-card__overlay-inner">
                  <p class="work-card__overlay-title">{item.data.title}</p>
                  <div class="work-card__overlay-meta">
                    <span class="work-card__overlay-type">
                      {typeLabel[item.data.type] ?? item.data.type}
                    </span>
                    <span class="work-card__overlay-year">{item.data.year}</span>
                  </div>
                </div>
              </div>
            </a>
          ))}
        </div>

        <!-- Older Entries Button -->
        <div class="older-entries" id="older-entries-wrap">
          <button class="older-entries__btn" id="older-entries-btn" aria-label="Load older entries">
            OLDER ENTRIES
          </button>
          <span class="older-entries__line" aria-hidden="true"></span>
        </div>
      )
    }
  </div>
</BaseLayout>

<style>
  .container {
    max-width: 80rem;
    margin-inline: auto;
    padding-inline: 1.5rem;
    padding-bottom: 6rem;
  }

  /* ── Header ── */
  .page-header {
    padding-block: 4rem 2.5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2rem;
  }

  .page-title {
    font-size: clamp(2rem, 5vw, 3.25rem);
    margin: 0 0 1rem;
    color: var(--color-text);
  }

  .page-desc {
    font-size: 1rem;
    color: var(--color-text-muted);
    max-width: 52ch;
    margin: 0;
    line-height: 1.75;
  }

  /* ── Filter ── */
  .filter-bar {
    display: flex;
    gap: 0.375rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .filter-btn {
    font-size: 0.8125rem;
    padding: 0.375rem 0.875rem;
    border-radius: 99px;
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all 0.15s;
  }

  .filter-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .filter-btn[aria-selected="true"] {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #fff;
  }

  /* ── Work Grid (3-column tight) ── */
  .work-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
  }

  /* ── Card ── */
  .work-card {
    display: block;
    position: relative;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    aspect-ratio: 1 / 1;
    background: var(--color-bg-subtle);
  }

  .work-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .work-card:hover .work-card__img {
    transform: scale(1.05);
  }

  /* Placeholder tanpa gambar */
  .work-card__noimage {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg-subtle);
    font-family: var(--font-serif);
    font-size: 3.5rem;
    font-style: italic;
    color: var(--color-text-muted);
  }

  /* ── Overlay — hanya muncul saat hover ── */
  .work-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.72) 0%,
      rgba(0, 0, 0, 0.28) 40%,
      transparent 65%
    );
    display: flex;
    align-items: flex-end;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .work-card:hover .work-card__overlay {
    opacity: 1;
  }

  .work-card__overlay-inner {
    padding: 1rem;
    width: 100%;
    transform: translateY(6px);
    transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .work-card:hover .work-card__overlay-inner {
    transform: translateY(0);
  }

  .work-card__overlay-title {
    font-size: 0.9rem;
    font-weight: 500;
    color: #fff;
    margin: 0 0 0.25rem;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .work-card__overlay-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .work-card__overlay-type {
    font-size: 0.65rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: rgba(255, 255, 255, 0.7);
  }

  .work-card__overlay-year {
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.55);
    font-family: var(--font-serif);
    font-style: italic;
  }

  /* ── Hidden saat filter ── */
  .work-card.hidden {
    display: none;
  }

  /* ── Empty state ── */
  .empty-state {
    padding: 5rem 0;
    text-align: center;
    color: var(--color-text-muted);
    font-style: italic;
    font-family: var(--font-serif);
    font-size: 1.125rem;
  }

  /* ── Older Entries ── */
  .older-entries {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 3rem 0 1rem;
    gap: 0;
  }

  .older-entries__btn {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    color: var(--color-accent, #8c7a5e);
    text-transform: uppercase;
    padding: 0.25rem 0;
    transition: opacity 0.2s;
  }

  .older-entries__btn:hover {
    opacity: 0.6;
  }

  .older-entries__line {
    display: block;
    width: 1px;
    height: 3.5rem;
    background: var(--color-border);
    margin-top: 0.75rem;
  }

  .older-entries[hidden] {
    display: none;
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .work-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 0;
    }
  }

  @media (max-width: 380px) {
    .work-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const PAGE_SIZE = 9;
  let visibleCount = PAGE_SIZE;
  let activeFilter = 'all';

  const allCards       = Array.from(document.querySelectorAll<HTMLElement>('.work-card'));
  const filterBtns     = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const olderWrap      = document.getElementById('older-entries-wrap');
  const olderBtn       = document.getElementById('older-entries-btn');

  function getFilteredCards() {
    return allCards.filter(c =>
      activeFilter === 'all' || c.dataset.type === activeFilter
    );
  }

  function applyVisibility() {
    const filtered = getFilteredCards();
    allCards.forEach(c => c.classList.add('hidden'));
    filtered.forEach((c, i) => {
      if (i < visibleCount) c.classList.remove('hidden');
    });
    // Show/hide older-entries button
    if (olderWrap) {
      if (visibleCount >= filtered.length) {
        olderWrap.setAttribute('hidden', '');
      } else {
        olderWrap.removeAttribute('hidden');
      }
    }
  }

  // Initial render
  applyVisibility();

  // ── Older Entries button ──
  olderBtn?.addEventListener('click', () => {
    visibleCount += PAGE_SIZE;
    applyVisibility();
  });

  // ── Filter tabs ──
  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      activeFilter = btn.dataset.filter ?? 'all';
      visibleCount = PAGE_SIZE; // reset ke halaman pertama

      filterBtns.forEach((b) => b.setAttribute('aria-selected', 'false'));
      btn.setAttribute('aria-selected', 'true');

      applyVisibility();
    });
  });
</script>
