---
// src/pages/work/index.astro
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const allWork = await getCollection("work");
const work = allWork.sort((a, b) => a.data.order - b.data.order);

const types = ["all", ...new Set(work.map((w) => w.data.type))];

const typeLabel: Record<string, string> = {
  all: "All",
  illustration: "Illustration",
  commission: "Commission",
  generative: "Generative",
  other: "Other",
};

// Aspect ratio hints per karya — fallback ke 1/1 kalau tidak ada cover
// Grid row span dihitung di client dari naturalHeight/naturalWidth gambar
---

<BaseLayout
  title="Work"
  description="Kumpulan karya ilustrasi — personal, commission, dan eksperimen generatif."
>
  <div class="container">
    <!-- Header -->
    <header class="page-header">
      <h1 class="page-title">Work</h1>
      <p class="page-desc">
        Karya-karya yang lahir dari sela-sela waktu — di malam hari, di akhir
        pekan, dan di momen tenang yang susah payah saya jaga.
      </p>
    </header>

    <!-- Filter tabs -->
    <div class="filter-bar" role="tablist" aria-label="Filter karya">
      {
        types.map((type) => (
          <button
            class="filter-btn"
            data-filter={type}
            role="tab"
            aria-selected={type === "all" ? "true" : "false"}
          >
            {typeLabel[type] ?? type}
          </button>
        ))
      }
    </div>

    <!-- Masonry Grid -->
    {
      work.length === 0 ? (
        <div class="empty-state">
          <p>Karya sedang dalam perjalanan. Nantikan.</p>
        </div>
      ) : (
        <div class="masonry-grid" id="masonry-grid">
          {work.map((item) => (
            <a
              href={`/work/${item.id}`}
              class="masonry-card"
              data-type={item.data.type}
              aria-label={item.data.title}
            >
              <div class="masonry-card__image-wrap">
                {item.data.cover ? (
                  <img
                    class="masonry-card__img"
                    src={item.data.cover}
                    alt={item.data.coverAlt ?? item.data.title}
                    loading="lazy"
                    decoding="async"
                  />
                ) : (
                  <div class="masonry-card__noimage">
                    <span>{item.data.title.charAt(0)}</span>
                  </div>
                )}

                <!-- Overlay info muncul saat scroll / hover -->
                <div class="masonry-card__overlay" aria-hidden="true">
                  <div class="masonry-card__overlay-inner">
                    <p class="masonry-card__overlay-title">{item.data.title}</p>
                    <div class="masonry-card__overlay-meta">
                      <span class="masonry-card__overlay-type">
                        {typeLabel[item.data.type] ?? item.data.type}
                      </span>
                      <span class="masonry-card__overlay-year">{item.data.year}</span>
                    </div>
                  </div>
                </div>
              </div>
            </a>
          ))}
        </div>
      )
    }
  </div>
</BaseLayout>

<style>
  .container {
    max-width: 80rem;
    margin-inline: auto;
    padding-inline: 1.5rem;
    padding-bottom: 6rem;
  }

  /* ── Header ── */
  .page-header {
    padding-block: 4rem 2.5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2rem;
  }

  .page-title {
    font-size: clamp(2rem, 5vw, 3.25rem);
    margin: 0 0 1rem;
    color: var(--color-text);
  }

  .page-desc {
    font-size: 1rem;
    color: var(--color-text-muted);
    max-width: 52ch;
    margin: 0;
    line-height: 1.75;
  }

  /* ── Filter ── */
  .filter-bar {
    display: flex;
    gap: 0.375rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .filter-btn {
    font-size: 0.8125rem;
    padding: 0.375rem 0.875rem;
    border-radius: 99px;
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all 0.15s;
  }

  .filter-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .filter-btn[aria-selected="true"] {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #fff;
  }

  /* ── Masonry Grid ── */
  /*
   * Teknik: CSS Grid dengan row-height kecil (8px).
   * Setiap card mendapat grid-row: span N via JS,
   * sehingga tinggi card mengikuti rasio gambar asli.
   */
  .masonry-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    grid-auto-rows: 8px;
    gap: 12px;
  }

  /* ── Card ── */
  .masonry-card {
    display: block;
    text-decoration: none;
    color: inherit;
    border-radius: 14px;
    overflow: hidden;
    /* Span dihitung JS, card mengisi baris grid */
    align-self: start;
  }

  .masonry-card__image-wrap {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    border-radius: 14px;
    background: var(--color-bg-subtle);
  }

  .masonry-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.45s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    border-radius: 14px;
  }

  .masonry-card:hover .masonry-card__img {
    transform: scale(1.04);
  }

  /* Placeholder tanpa gambar */
  .masonry-card__noimage {
    width: 100%;
    aspect-ratio: 3/4;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg-subtle);
    font-family: var(--font-serif);
    font-size: 3.5rem;
    font-style: italic;
    color: var(--color-text-muted);
  }

  /* ── Overlay ── */
  .masonry-card__overlay {
    position: absolute;
    inset: 0;
    border-radius: 14px;
    /* Gradient gelap dari bawah */
    background: linear-gradient(
      to top,
      color-mix(in srgb, #000 75%, transparent) 0%,
      color-mix(in srgb, #000 30%, transparent) 35%,
      transparent 60%
    );
    display: flex;
    align-items: flex-end;
    /* Default: overlay tersembunyi, muncul via JS saat card masuk viewport */
    opacity: 0;
    transition: opacity 0.35s ease;
    pointer-events: none;
  }

  /* Saat hover */
  .masonry-card:hover .masonry-card__overlay {
    opacity: 1;
  }

  /* Saat in-viewport (kelas ditambahkan JS) */
  .masonry-card.is-visible .masonry-card__overlay {
    opacity: 1;
  }

  .masonry-card__overlay-inner {
    padding: 1.125rem 1rem 1rem;
    width: 100%;
    /* Konten slide up dari bawah */
    transform: translateY(8px);
    transition: transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .masonry-card:hover .masonry-card__overlay-inner,
  .masonry-card.is-visible .masonry-card__overlay-inner {
    transform: translateY(0);
  }

  .masonry-card__overlay-title {
    font-size: 0.9375rem;
    font-weight: 500;
    color: #fff;
    margin: 0 0 0.375rem;
    line-height: 1.3;
    /* Clamp panjang judul */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .masonry-card__overlay-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .masonry-card__overlay-type {
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: rgba(255, 255, 255, 0.7);
  }

  .masonry-card__overlay-year {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.55);
    font-family: var(--font-serif);
    font-style: italic;
  }

  /* ── Hidden saat filter ── */
  .masonry-card.hidden {
    display: none;
  }

  /* ── Empty state ── */
  .empty-state {
    padding: 5rem 0;
    text-align: center;
    color: var(--color-text-muted);
    font-style: italic;
    font-family: var(--font-serif);
    font-size: 1.125rem;
  }

  /* ── Responsive ── */
  @media (max-width: 480px) {
    .masonry-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 8px;
    }

    .masonry-card {
      border-radius: 10px;
    }

    .masonry-card__image-wrap,
    .masonry-card__img,
    .masonry-card__overlay {
      border-radius: 10px;
    }
  }

  @media (min-width: 481px) and (max-width: 768px) {
    .masonry-grid {
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    }
  }
</style>

<script>
  // ── 1. Masonry span: setiap card mendapat grid-row: span N ──
  const ROW_HEIGHT = 8;   // harus sama dengan grid-auto-rows di CSS
  const GAP       = 12;   // harus sama dengan gap di CSS

  function setSpan(card: HTMLElement) {
    const img = card.querySelector<HTMLImageElement>('.masonry-card__img');
    const wrap = card.querySelector<HTMLElement>('.masonry-card__image-wrap');
    if (!wrap) return;

    // Ambil lebar card untuk hitung tinggi proporsional
    const cardWidth = card.getBoundingClientRect().width;

    let targetHeight: number;

    if (img && img.naturalWidth && img.naturalHeight) {
      targetHeight = (cardWidth * img.naturalHeight) / img.naturalWidth;
    } else {
      // Fallback: rasio 4:5 (portrait)
      targetHeight = cardWidth * 1.25;
    }

    const span = Math.ceil((targetHeight + GAP) / (ROW_HEIGHT + GAP));
    card.style.gridRowEnd = `span ${span}`;
  }

  function initMasonry() {
    const cards = document.querySelectorAll<HTMLElement>('.masonry-card');
    cards.forEach((card) => {
      const img = card.querySelector<HTMLImageElement>('.masonry-card__img');
      if (img) {
        if (img.complete && img.naturalWidth) {
          setSpan(card);
        } else {
          img.addEventListener('load', () => setSpan(card), { once: true });
        }
      } else {
        // Kartu tanpa gambar — rasio portrait default
        setSpan(card);
      }
    });
  }

  // Re-hitung saat resize (debounced)
  let resizeTimer: ReturnType<typeof setTimeout>;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(initMasonry, 120);
  });

  initMasonry();

  // ── 2. Intersection Observer: overlay muncul saat card terlihat saat scroll ──
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        const card = entry.target as HTMLElement;
        if (entry.isIntersecting) {
          card.classList.add('is-visible');
        } else {
          // Hapus kelas saat keluar viewport agar bisa muncul lagi saat scroll balik
          card.classList.remove('is-visible');
        }
      });
    },
    {
      threshold: 0.15,         // muncul saat 15% card terlihat
      rootMargin: '0px 0px -5% 0px',
    }
  );

  document.querySelectorAll<HTMLElement>('.masonry-card').forEach((card) => {
    observer.observe(card);
  });

  // ── 3. Filter tabs ──
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const allCards   = document.querySelectorAll<HTMLElement>('.masonry-card');

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter ?? 'all';

      filterBtns.forEach((b) => b.setAttribute('aria-selected', 'false'));
      btn.setAttribute('aria-selected', 'true');

      allCards.forEach((card) => {
        const match = filter === 'all' || card.dataset.type === filter;
        card.classList.toggle('hidden', !match);
      });

      // Re-hitung span setelah filter (layout berubah)
      setTimeout(initMasonry, 50);
    });
  });
</script>
