---
// src/components/Nav.astro
const navLinks = [
  { href: "/work", label: "Work" },
  { href: "/blog", label: "Blog" },
  { href: "/now", label: "Now" },
  { href: "/about", label: "About" },
];

const currentPath = Astro.url.pathname;
---

<header class="nav-header">
  <nav class="nav-inner">
    <!-- Logo / nama -->
    <a href="/" class="nav-logo">
      <span class="nav-logo-name">Teguh Suwanda</span>
      <span class="nav-logo-tagline">engineer · illustrator</span>
    </a>

    <!-- Desktop links -->
    <ul class="nav-links" role="list">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={[
                "nav-link",
                { "nav-link--active": currentPath.startsWith(link.href) },
              ]}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- Kanan: dark mode toggle + hamburger -->
    <div class="nav-actions">
      <button
        id="theme-toggle"
        class="icon-btn"
        aria-label="Toggle dark mode"
        title="Toggle dark mode"
      >
        <svg
          class="icon-sun"
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <circle cx="12" cy="12" r="4"></circle>
          <path
            d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"
          ></path>
        </svg>
        <svg
          class="icon-moon"
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
        </svg>
      </button>

      <!-- Hamburger — hanya muncul di mobile -->
      <button
        id="menu-toggle"
        class="icon-btn hamburger"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-drawer"
      >
        <svg
          class="ham-icon"
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
        >
          <line class="ham-top" x1="3" y1="6" x2="21" y2="6"></line>
          <line class="ham-mid" x1="3" y1="12" x2="21" y2="12"></line>
          <line class="ham-bot" x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>
  </nav>
</header>

<!-- Backdrop -->
<div id="mobile-backdrop" aria-hidden="true"></div>

<!-- Mobile drawer -->
<div
  id="mobile-drawer"
  role="dialog"
  aria-label="Menu navigasi"
  aria-modal="true"
>
  <ul class="drawer-links" role="list">
    {
      navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              "drawer-link",
              { "drawer-link--active": currentPath.startsWith(link.href) },
            ]}
          >
            {link.label}
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M5 12h14M13 6l6 6-6 6" />
            </svg>
          </a>
        </li>
      ))
    }
  </ul>

  <div class="drawer-footer">
    <p class="drawer-name">Teguh Suwanda</p>
    <p class="drawer-tagline">engineer · illustrator · family man</p>
  </div>
</div>

<style>
  /* ── Header ── */
  .nav-header {
    position: sticky;
    top: 0;
    z-index: 50;
    border-bottom: 1px solid var(--color-border);
    backdrop-filter: blur(8px);
    background-color: color-mix(in srgb, var(--color-bg) 85%, transparent);
  }

  .nav-inner {
    max-width: 72rem;
    margin-inline: auto;
    padding-inline: 1.5rem;
    height: 3.5rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  /* ── Logo ── */
  .nav-logo {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
    margin-right: auto;
    text-decoration: none;
    flex-shrink: 0;
  }

  .nav-logo-name {
    font-family: var(--font-serif);
    font-size: 1rem;
    font-variation-settings: "opsz" 9;
    color: var(--color-text);
    white-space: nowrap;
  }

  .nav-logo-tagline {
    font-size: 0.65rem;
    color: var(--color-text-muted);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  /* ── Desktop links ── */
  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    padding: 0.375rem 0.75rem;
    border-radius: 6px;
    text-decoration: none;
    transition:
      color 0.15s,
      background-color 0.15s;
    white-space: nowrap;
  }

  .nav-link:hover {
    color: var(--color-text);
    background-color: var(--color-bg-subtle);
  }

  .nav-link--active {
    color: var(--color-accent);
    font-weight: 500;
  }

  /* ── Tombol kanan (theme + hamburger) ── */
  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    flex-shrink: 0;
  }

  .icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 6px;
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-text-muted);
    cursor: pointer;
    transition:
      color 0.15s,
      background-color 0.15s;
    flex-shrink: 0;
  }

  .icon-btn:hover {
    color: var(--color-text);
    background-color: var(--color-bg-subtle);
  }

  /* Animasi garis hamburger → X */
  .ham-icon {
    display: block;
    overflow: visible;
  }
  .ham-top,
  .ham-mid,
  .ham-bot {
    transform-origin: center;
    transition:
      transform 0.25s ease,
      opacity 0.2s;
  }

  [aria-expanded="true"] .ham-top {
    transform: translateY(6px) rotate(45deg);
  }
  [aria-expanded="true"] .ham-mid {
    opacity: 0;
    transform: scaleX(0);
  }
  [aria-expanded="true"] .ham-bot {
    transform: translateY(-6px) rotate(-45deg);
  }

  /* Sembunyikan icon tema yang tidak aktif */
  :root:not(.dark) .icon-moon {
    display: none;
  }
  :root.dark .icon-sun {
    display: none;
  }

  /* Sembunyikan hamburger di desktop */
  .hamburger {
    display: none;
  }

  /* ── Backdrop ── */
  #mobile-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 40;
    background: color-mix(in srgb, var(--color-text) 40%, transparent);
    backdrop-filter: blur(2px);
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  #mobile-backdrop.is-open {
    display: block;
    opacity: 1;
  }

  /* ── Mobile drawer ── */
  #mobile-drawer {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    z-index: 60;
    width: min(280px, 80vw);
    background: var(--color-bg);
    border-left: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    padding: 5rem 1.5rem 2rem;
    transform: translateX(100%);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    visibility: hidden;
  }

  #mobile-drawer.is-open {
    transform: translateX(0);
    visibility: visible;
  }

  .drawer-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    flex: 1;
  }

  .drawer-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.875rem 1rem;
    border-radius: 10px;
    font-size: 1.0625rem;
    font-weight: 500;
    color: var(--color-text-muted);
    text-decoration: none;
    transition:
      background-color 0.15s,
      color 0.15s;
  }

  .drawer-link svg {
    opacity: 0;
    transform: translateX(-4px);
    transition:
      opacity 0.15s,
      transform 0.15s;
    flex-shrink: 0;
  }

  .drawer-link:hover {
    background-color: var(--color-bg-subtle);
    color: var(--color-text);
  }

  .drawer-link:hover svg {
    opacity: 1;
    transform: translateX(0);
  }

  .drawer-link--active {
    color: var(--color-accent);
    background-color: var(--color-accent-soft);
  }

  .drawer-link--active svg {
    opacity: 1;
    transform: translateX(0);
    color: var(--color-accent);
  }

  .drawer-footer {
    border-top: 1px solid var(--color-border);
    padding-top: 1.25rem;
  }

  .drawer-name {
    font-family: var(--font-serif);
    font-size: 0.9375rem;
    color: var(--color-text);
    margin: 0 0 0.25rem;
  }

  .drawer-tagline {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin: 0;
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    /* Sembunyikan desktop links, tampilkan hamburger */
    .nav-links {
      display: none;
    }
    .hamburger {
      display: flex;
    }

    .nav-logo-tagline {
      display: none;
    }

    .nav-inner {
      padding-inline: 1rem;
      gap: 0.75rem;
    }
  }

  @media (min-width: 641px) {
    /* Pastikan drawer tidak pernah tampil di desktop */
    #mobile-drawer,
    #mobile-backdrop {
      display: none !important;
    }
  }
</style>

<script>
  // ── Theme toggle ──
  const getTheme = () =>
    localStorage.getItem("theme") ??
    (window.matchMedia("(prefers-color-scheme: dark)").matches
      ? "dark"
      : "light");

  const applyTheme = (theme: string) => {
    document.documentElement.classList.toggle("dark", theme === "dark");
    localStorage.setItem("theme", theme);
  };

  applyTheme(getTheme());

  document.getElementById("theme-toggle")?.addEventListener("click", () => {
    const next = document.documentElement.classList.contains("dark")
      ? "light"
      : "dark";
    applyTheme(next);
  });

  // ── Mobile drawer ──
  const menuBtn = document.getElementById("menu-toggle") as HTMLButtonElement;
  const drawer = document.getElementById("mobile-drawer") as HTMLElement;
  const backdrop = document.getElementById("mobile-backdrop") as HTMLElement;

  let isOpen = false;

  function openDrawer() {
    isOpen = true;
    menuBtn.setAttribute("aria-expanded", "true");
    drawer.classList.add("is-open");
    backdrop.classList.add("is-open");
    document.body.style.overflow = "hidden";

    // Fokus ke link pertama di drawer (aksesibilitas)
    const firstLink = drawer.querySelector<HTMLAnchorElement>(".drawer-link");
    firstLink?.focus();
  }

  function closeDrawer() {
    isOpen = false;
    menuBtn.setAttribute("aria-expanded", "false");
    drawer.classList.remove("is-open");
    backdrop.classList.remove("is-open");
    document.body.style.overflow = "";
    menuBtn.focus();
  }

  menuBtn?.addEventListener("click", () => {
    isOpen ? closeDrawer() : openDrawer();
  });

  // Tutup saat klik backdrop
  backdrop?.addEventListener("click", closeDrawer);

  // Tutup saat tekan Escape
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && isOpen) closeDrawer();
  });

  // Tutup otomatis saat klik link di dalam drawer (navigasi)
  drawer?.querySelectorAll(".drawer-link").forEach((link) => {
    link.addEventListener("click", closeDrawer);
  });

  // Trap focus di dalam drawer saat terbuka
  drawer?.addEventListener("keydown", (e) => {
    if (!isOpen || e.key !== "Tab") return;
    const focusable = drawer.querySelectorAll<HTMLElement>(
      'a[href], button, [tabindex]:not([tabindex="-1"])',
    );
    const first = focusable[0];
    const last = focusable[focusable.length - 1];
    if (e.shiftKey && document.activeElement === first) {
      e.preventDefault();
      last.focus();
    } else if (!e.shiftKey && document.activeElement === last) {
      e.preventDefault();
      first.focus();
    }
  });
</script>
